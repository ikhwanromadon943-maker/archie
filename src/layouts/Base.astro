---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Search and discover music.">

  <div class="music-hero">
    <h1 class="music-big-title">ARCHIE<span class="music-dot">.</span>MUSIC</h1>
    <div class="music-search-row">
      <div class="music-search-wrap">
        <div class="music-search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </div>
        <input type="text" id="music-search" class="music-search-input" placeholder="Search song..."/>
      </div>
      <button id="music-search-btn" class="music-search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Visualizer bar -->
  <div class="music-visualizer" id="music-viz" style="display:none">
    <div class="music-viz-inner">
      <div class="viz-label">NOW PLAYING</div>
      <div class="viz-bars">
        <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
        <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
        <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
        <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
      </div>
      <div class="viz-track" id="viz-track-name">—</div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="music-stats" id="music-stats" style="display:none">
    <div class="music-stat-item">
      <span class="music-stat-val" id="stat-count">0</span>
      <span class="music-stat-label">Tracks</span>
    </div>
    <div class="music-stat-sep"></div>
    <div class="music-stat-item">
      <span class="music-stat-val" id="stat-artist">—</span>
      <span class="music-stat-label">Artists</span>
    </div>
    <div class="music-stat-sep"></div>
    <div class="music-stat-item">
      <span class="music-stat-val" id="stat-duration">—</span>
      <span class="music-stat-label">Total Time</span>
    </div>
  </div>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div id="music-list"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
      </svg>
    </div>
    <h3 class="music-empty-label">START BY SEARCHING A SONG</h3>
    <p>Or add tracks via the admin panel.</p>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';
  
  // FIXED: Hapus TypeScript annotations
  let allTracks = [];
  let activeCard = null;

  function parseDuration(dur) {
    if (!dur) return 0;
    const parts = dur.split(':').map(Number);
    if (parts.length === 2) return parts[0] * 60 + parts[1];
    if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
    return 0;
  }

  function formatTotal(secs) {
    const h = Math.floor(secs / 3600);
    const m = Math.floor((secs % 3600) / 60);
    if (h > 0) return `${h}h ${m}m`;
    return `${m}m`;
  }

  // FIXED: Safety checks - hapus non-null assertion
  function updateStats(items) {
    const statsEl = document.getElementById('music-stats');
    if (!statsEl) return;
    if (!items.length) {
      statsEl.style.display = 'none';
      return;
    }
    statsEl.style.display = 'flex';
    const artists = new Set(items.map(t => t.artist).filter(Boolean));
    const totalSecs = items.reduce((acc, t) => acc + parseDuration(t.duration || ''), 0);
    
    const countEl = document.getElementById('stat-count');
    const artistEl = document.getElementById('stat-artist');
    const durationEl = document.getElementById('stat-duration');
    
    if (countEl) countEl.textContent = String(items.length);
    if (artistEl) artistEl.textContent = String(artists.size);
    if (durationEl) durationEl.textContent = formatTotal(totalSecs) || '—';
  }

  async function loadTracks() {
    const loading = document.getElementById('loading');
    const empty = document.getElementById('empty-state');
    
    if (!loading || !empty) return;
    
    const { data: items, error } = await supabase
      .from('music')
      .select('*')
      .order('added_at', { ascending: false });
    
    loading.style.display = 'none';
    
    if (error || !items || items.length === 0) {
      empty.style.display = 'block';
      return;
    }
    allTracks = items;
    renderTracks(items);
    updateStats(items);
  }

  // FIXED: Escape HTML to prevent XSS
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  function renderTracks(items) {
    const list = document.getElementById('music-list');
    const empty = document.getElementById('empty-state');
    
    if (!list || !empty) return;
    
    list.innerHTML = '';
    
    if (!items.length) {
      empty.style.display = 'block';
      updateStats([]);
      return;
    }
    empty.style.display = 'none';

    items.forEach((item, i) => {
      const escapedTitle = escapeHtml(item.title);
      const escapedArtist = escapeHtml(item.artist);
      const escapedThumb = item.thumbnail ? escapeHtml(item.thumbnail) : '';
      const escapedUrl = item.url ? escapeHtml(item.url) : '';

      const card = document.createElement('div');
      card.className = 'music-card';
      card.style.cssText = `opacity:0;animation:fadeUp 0.4s ease ${i * 0.05}s forwards`;
      
      card.innerHTML = `
        ${item.thumbnail
          ? `<img class="music-thumb" src="${escapedThumb}" alt="${escapedTitle}" loading="lazy"/>`
          : `<div class="music-thumb music-thumb-ph">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
              </svg>
            </div>`}
        <div class="music-info">
          <div class="music-name">${escapedTitle}</div>
          <div class="music-artist">${escapedArtist}</div>
        </div>
        <div class="music-duration">${item.duration || '—'}</div>
        ${item.url ? `<a href="${escapedUrl}" target="_blank" rel="noopener noreferrer" class="music-link" title="Open" onclick="event.stopPropagation()">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>` : ''}`;

      // Click to "play" — highlight card + show visualizer
      card.addEventListener('click', () => {
        const viz = document.getElementById('music-viz');
        const vizTrack = document.getElementById('viz-track-name');
        
        if (!viz || !vizTrack) return;
        
        if (activeCard === card) {
          card.classList.remove('playing');
          activeCard = null;
          viz.style.display = 'none';
        } else {
          if (activeCard) activeCard.classList.remove('playing');
          card.classList.add('playing');
          activeCard = card;
          vizTrack.textContent = `${item.title} — ${item.artist}`;
          viz.style.display = 'flex';
        }
      });

      list.appendChild(card);
    });
  }

  loadTracks();

  // FIXED: Safety checks untuk search
  const searchInput = document.getElementById('music-search');
  const searchBtn = document.getElementById('music-search-btn');
  
  const doSearch = () => {
    if (!searchInput) return;
    const q = searchInput.value.toLowerCase().trim();
    const filtered = !q ? allTracks : allTracks.filter(t => 
      t.title.toLowerCase().includes(q) || 
      t.artist.toLowerCase().includes(q)
    );
    renderTracks(filtered);
    updateStats(filtered);
  };
  
  if (searchInput) {
    searchInput.addEventListener('input', doSearch);
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') doSearch();
    });
  }
  
  if (searchBtn) {
    searchBtn.addEventListener('click', doSearch);
  }
</script>

<style is:global>
  /* FIXED: Gunakan is:global agar CSS apply ke innerHTML elements */
  
  .music-hero { 
    text-align: center; 
    padding: 2rem 0 2rem; 
  }
  
  .music-big-title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 9vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 2rem;
    line-height: 1;
  }
  
  .music-dot { 
    color: var(--blue); 
  }
  
  .music-search-row { 
    display: flex; 
    gap: 0.5rem; 
    max-width: 400px; 
    margin: 0 auto; 
  }
  
  .music-search-wrap { 
    flex: 1; 
    position: relative; 
  }
  
  .music-search-icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-mute);
    pointer-events: none;
    display: flex;
  }
  
  .music-search-input {
    width: 100%;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    border: 1.5px solid rgba(255, 255, 255, 0.9);
    border-radius: 999px;
    padding: 0.7rem 1rem 0.7rem 2.5rem;
    font-size: 0.875rem;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }
  
  .music-search-input:focus { 
    border-color: var(--blue); 
    box-shadow: 0 0 0 3px rgba(100, 149, 237, 0.12); 
  }
  
  .music-search-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 12px rgba(100, 149, 237, 0.3);
  }
  
  .music-search-btn:hover { 
    background: var(--blue-hover); 
    transform: scale(1.05); 
  }

  /* Visualizer */
  .music-visualizer {
    margin: 1rem 0;
    padding: 0.85rem 1.2rem;
    background: rgba(255, 255, 255, 0.60);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.82);
    border-radius: 16px;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    box-shadow: 0 4px 20px rgba(100, 149, 237, 0.09);
    animation: fadeUp 0.35s ease forwards;
  }
  
  .music-viz-inner { 
    display: flex; 
    align-items: center; 
    gap: 0.9rem; 
    width: 100%; 
  }
  
  .viz-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--blue);
    letter-spacing: 0.14em;
    font-weight: 700;
    flex-shrink: 0;
    opacity: 0.75;
  }
  
  .viz-bars { 
    display: flex; 
    align-items: flex-end; 
    gap: 2.5px; 
    height: 22px; 
    flex-shrink: 0; 
  }
  
  .viz-bar {
    width: 3px;
    border-radius: 2px;
    background: var(--blue);
    opacity: 0.7;
    animation: vizBounce var(--dur, 0.8s) ease-in-out infinite alternate;
    height: var(--h, 10px);
  }
  
  .viz-bar:nth-child(1)  { --h: 8px;  --dur: 0.55s; animation-delay: 0s; }
  .viz-bar:nth-child(2)  { --h: 14px; --dur: 0.7s;  animation-delay: 0.07s; }
  .viz-bar:nth-child(3)  { --h: 10px; --dur: 0.6s;  animation-delay: 0.14s; }
  .viz-bar:nth-child(4)  { --h: 18px; --dur: 0.85s; animation-delay: 0.05s; }
  .viz-bar:nth-child(5)  { --h: 12px; --dur: 0.65s; animation-delay: 0.12s; }
  .viz-bar:nth-child(6)  { --h: 20px; --dur: 0.75s; animation-delay: 0.02s; }
  .viz-bar:nth-child(7)  { --h: 9px;  --dur: 0.58s; animation-delay: 0.19s; }
  .viz-bar:nth-child(8)  { --h: 16px; --dur: 0.9s;  animation-delay: 0.08s; }
  .viz-bar:nth-child(9)  { --h: 11px; --dur: 0.68s; animation-delay: 0.15s; }
  .viz-bar:nth-child(10) { --h: 19px; --dur: 0.78s; animation-delay: 0.03s; }
  .viz-bar:nth-child(11) { --h: 7px;  --dur: 0.62s; animation-delay: 0.22s; }
  .viz-bar:nth-child(12) { --h: 14px; --dur: 0.72s; animation-delay: 0.10s; }
  
  @keyframes vizBounce { 
    from { transform: scaleY(0.25); } 
    to { transform: scaleY(1); } 
  }
  
  .viz-track {
    font-size: 0.72rem;
    color: var(--text-dim);
    font-weight: 500;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Stats */
  .music-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.8rem 1rem;
    margin-bottom: 1.25rem;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 14px;
    animation: fadeUp 0.4s ease 0.1s forwards;
    opacity: 0;
  }
  
  .music-stat-item { 
    text-align: center; 
  }
  
  .music-stat-val {
    display: block;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--blue);
  }
  
  .music-stat-label {
    display: block;
    font-size: 0.6rem;
    color: var(--text-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.1rem;
  }
  
  .music-stat-sep {
    width: 1px;
    height: 32px;
    background: rgba(148, 163, 184, 0.3);
  }

  /* Track cards */
  .music-card {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    margin-bottom: 0.35rem;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 14px;
    transition: all 0.25s ease;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(100, 149, 237, 0.05);
  }
  
  .music-card:hover {
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 4px 16px rgba(100, 149, 237, 0.1);
    transform: translateY(-1px);
  }
  
  .music-card.playing {
    background: rgba(100, 149, 237, 0.08);
    border-color: rgba(100, 149, 237, 0.3);
    box-shadow: 0 4px 20px rgba(100, 149, 237, 0.15);
  }
  
  .music-thumb {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
    background: #f1f5f9;
  }
  
  .music-thumb-ph {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    flex-shrink: 0;
    background: #eff6ff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    opacity: 0.6;
  }
  
  .music-info { 
    flex: 1; 
    min-width: 0; 
  }
  
  .music-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .music-artist {
    font-size: 0.72rem;
    color: var(--text-mute);
    margin-top: 0.1rem;
  }
  
  .music-duration {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-mute);
    flex-shrink: 0;
  }
  
  .music-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    color: var(--blue);
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  
  .music-link:hover {
    background: #eff6ff;
    border-color: var(--blue);
  }
  
  .empty-icon {
    display: flex;
    justify-content: center;
    color: var(--blue);
    opacity: 0.2;
    margin-bottom: 1rem;
  }
  
  .music-empty-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    font-weight: 500;
  }
</style>