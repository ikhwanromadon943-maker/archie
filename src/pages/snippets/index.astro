---
import Base from '../../layouts/Base.astro';
---
<Base title="Code Library" description="Fragments of logic, syntax, and solutions.">

  <header class="snip-hdr">
    <h1>Code Library</h1>
    <p>Fragments of logic, syntax, and solutions.</p>
  </header>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div class="snip-feed" id="snip-list"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </div>
    <h3>No snippets yet.</h3>
    <p>The first snippet has yet to be saved.</p>
  </div>

  <!-- Code Modal -->
  <div class="modal-overlay" id="snip-modal">
    <div class="modal">
      <div class="modal-header">
        <h2 class="modal-title" id="modal-title">—</h2>
        <button class="modal-close" id="modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <p class="modal-desc" id="modal-desc"></p>
      <div class="code-wrapper">
        <div class="code-header">
          <span id="modal-lang">js</span>
          <button class="code-copy" id="copy-btn">copy</button>
        </div>
        <pre class="code-body"><code id="modal-code"></code></pre>
      </div>
    </div>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  // Permanent like tracking in localStorage
  const LS_LIKED = 'liked_snippets_v1';
  
  // FIXED: Hapus TypeScript annotations
  const getSnipLiked = () => {
    try { 
      return new Set(JSON.parse(localStorage.getItem(LS_LIKED) || '[]')); 
    } catch { 
      return new Set(); 
    }
  };
  
  const saveSnipLiked = (s) => localStorage.setItem(LS_LIKED, JSON.stringify([...s]));

  const fdate = (iso) => new Date(iso).toLocaleDateString('en-US', { month: 'numeric', day: 'numeric', year: 'numeric' });
  let currentCode = '';

  // Local view counts (permanent per session) — views increment once per snippet per page load
  const viewedThisSession = new Set();

  // FIXED: Escape HTML to prevent XSS
  const escapeHtml = (str) => {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  };

  function getLangClass(lang) {
    const l = lang?.toLowerCase() || '';
    if (['js', 'javascript'].includes(l)) return 'lang-js';
    if (['ts', 'typescript'].includes(l)) return 'lang-ts';
    if (['py', 'python'].includes(l)) return 'lang-py';
    if (['sh', 'bash', 'shell'].includes(l)) return 'lang-sh';
    if (l === 'css') return 'lang-css';
    if (l === 'html') return 'lang-html';
    if (l === 'json') return 'lang-json';
    return 'lang-other';
  }

  // FIXED: Safety checks - hapus non-null assertion
  function openModal(s, el) {
    const modalTitle = document.getElementById('modal-title');
    const modalDesc = document.getElementById('modal-desc');
    const modalLang = document.getElementById('modal-lang');
    const modalCode = document.getElementById('modal-code');
    const modal = document.getElementById('snip-modal');
    
    if (!modalTitle || !modalDesc || !modalLang || !modalCode || !modal) return;
    
    currentCode = s.code;
    modalTitle.textContent = s.title;
    modalDesc.textContent = s.description || '';
    modalLang.textContent = s.language;
    modalCode.textContent = s.code;
    modal.classList.add('open');

    // Increment views only once per snippet per page visit
    if (!viewedThisSession.has(s.id)) {
      viewedThisSession.add(s.id);
      const viewEl = el.querySelector('.snip-stat-views span');
      if (viewEl) {
        const currentViews = parseInt(viewEl.textContent || '0');
        viewEl.textContent = String(currentViews + 1);
      }
      supabase.rpc('increment_views', { row_id: s.id });
    }
  }

  async function render() {
    // FIXED: Safety checks - hapus non-null assertion
    const loading = document.getElementById('loading');
    const list = document.getElementById('snip-list');
    const empty = document.getElementById('empty-state');
    
    if (!loading || !list || !empty) return;

    const { data: snippets, error } = await supabase
      .from('snippets')
      .select('*')
      .order('created_at', { ascending: false });

    loading.style.display = 'none';
    
    if (error) {
      list.innerHTML = `<p class="err-msg">[error] ${escapeHtml(error.message)}</p>`;
      return;
    }
    
    if (!snippets || snippets.length === 0) {
      empty.style.display = 'block';
      return;
    }

    const liked = getSnipLiked();

    snippets.forEach((s, i) => {
      const isLiked = liked.has(s.id);
      const escapedTitle = escapeHtml(s.title);
      const escapedDesc = s.description ? escapeHtml(s.description) : '';
      const escapedLang = escapeHtml(s.language || 'code');
      
      const el = document.createElement('div');
      el.className = 'snip-card';
      el.style.cssText = `opacity:0;animation:fadeUp 0.4s ease ${i * 0.06}s forwards`;

      el.innerHTML = `
        <div class="snip-card-body">
          <div class="snip-badge">
            <span class="snip-stat snip-stat-views">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <span>${s.views ?? 0}</span>
            </span>
            <div class="snip-sep"></div>
            <button class="snip-like-inline${isLiked ? ' liked' : ''}" data-id="${s.id}" data-liked="${isLiked}" aria-label="Like snippet">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="${isLiked ? '#ef4444' : 'none'}" stroke="${isLiked ? '#ef4444' : 'currentColor'}" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <span class="slc">${s.likes ?? 0}</span>
            </button>
          </div>

          <h3 class="snip-title">${escapedTitle}</h3>
          ${s.description ? `<p class="snip-desc">${escapedDesc}</p>` : ''}

          <div class="snip-foot">
            <span class="snip-lang ${getLangClass(s.language)}">${escapedLang}</span>
            <span class="snip-date">${fdate(s.created_at)}</span>
          </div>
        </div>`;

      // FIXED: Safety check untuk like button
      const likeBtn = el.querySelector('.snip-like-inline');
      if (likeBtn) {
        likeBtn.addEventListener('click', async function(e) {
          e.stopPropagation();
          const id = this.getAttribute('data-id');
          if (!id) return;
          
          const wasLiked = this.getAttribute('data-liked') === 'true';
          const likedSet = getSnipLiked();
          const slc = this.querySelector('.slc');
          const svg = this.querySelector('svg');
          
          if (!slc || !svg) return;
          
          const cur = parseInt(slc.textContent || '0');

          if (wasLiked) {
            likedSet.delete(id);
            this.setAttribute('data-liked', 'false');
            this.classList.remove('liked');
            svg.setAttribute('fill', 'none');
            svg.setAttribute('stroke', 'currentColor');
            slc.textContent = String(Math.max(0, cur - 1));
            await supabase.rpc('decrement_likes', { table_name: 'snippets', row_id: id });
          } else {
            likedSet.add(id);
            this.setAttribute('data-liked', 'true');
            this.classList.add('liked');
            svg.setAttribute('fill', '#ef4444');
            svg.setAttribute('stroke', '#ef4444');
            slc.textContent = String(cur + 1);
            await supabase.rpc('increment_likes', { table_name: 'snippets', row_id: id });
          }
          saveSnipLiked(likedSet);
        });
      }

      el.addEventListener('click', (e) => {
        const target = e.target;
        if (target && target.closest && target.closest('.snip-like-inline')) return;
        openModal(s, el);
      });
      
      list.appendChild(el);
    });
  }

  render();

  // FIXED: Safety checks untuk modal events
  const modalClose = document.getElementById('modal-close');
  const snipModal = document.getElementById('snip-modal');
  const copyBtn = document.getElementById('copy-btn');
  
  if (modalClose && snipModal) {
    modalClose.addEventListener('click', () => snipModal.classList.remove('open'));
  }
  
  if (snipModal) {
    snipModal.addEventListener('click', (e) => {
      if (e.target === snipModal) snipModal.classList.remove('open');
    });
  }
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && snipModal) snipModal.classList.remove('open');
  });
  
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(currentCode).then(() => {
        const btn = copyBtn;
        btn.textContent = 'copied!';
        setTimeout(() => btn.textContent = 'copy', 2000);
      });
    });
  }
</script>

<style is:global>
  /* FIXED: Gunakan is:global agar CSS apply ke innerHTML elements */
  
  .snip-hdr {
    margin-bottom: 1.75rem;
    margin-top: 0.5rem;
  }
  
  .snip-hdr h1 {
    font-family: var(--font-serif);
    font-size: 2.1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  
  .snip-hdr p {
    color: var(--text-mute);
    font-size: 0.82rem;
    margin-top: 0.3rem;
  }

  .snip-feed {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .snip-card {
    background: rgba(255, 255, 255, 0.60);
    backdrop-filter: blur(26px);
    -webkit-backdrop-filter: blur(26px);
    border: 1px solid rgba(255, 255, 255, 0.82);
    border-radius: 20px;
    cursor: pointer;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(100, 149, 237, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
  }
  
  .snip-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(100, 149, 237, 0.14), 0 2px 8px rgba(0, 0, 0, 0.05);
    border-color: rgba(100, 149, 237, 0.35);
  }
  
  .snip-card-body {
    padding: 1.1rem 1.2rem 1rem;
  }

  .snip-badge {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(248, 250, 252, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(241, 245, 249, 0.95);
    border-left: 1px solid rgba(241, 245, 249, 0.95);
    border-radius: 0 20px 0 14px;
    padding: 0.28rem 0.7rem;
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--text-mute);
    transition: background var(--ease);
  }
  
  .snip-card:hover .snip-badge {
    background: rgba(100, 149, 237, 0.08);
  }
  
  .snip-stat {
    display: flex;
    align-items: center;
    gap: 0.22rem;
    transition: color var(--ease);
  }
  
  .snip-card:hover .snip-stat-views {
    color: var(--blue);
  }
  
  .snip-card:hover .snip-stat-likes {
    color: #ef4444;
  }
  
  .snip-sep {
    width: 1px;
    height: 9px;
    background: #e2e8f0;
  }

  /* Like button inline in snip-badge */
  .snip-like-inline {
    display: flex;
    align-items: center;
    gap: 0.22rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--text-mute);
    transition: color 0.2s ease;
  }
  
  .snip-like-inline:hover {
    color: #ef4444;
  }
  
  .snip-like-inline.liked {
    color: #ef4444;
  }
  
  .snip-card:hover .snip-like-inline:not(.liked) {
    color: #f87171;
  }

  .snip-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.32rem;
    padding-right: 5.5rem;
    transition: color var(--ease);
  }
  
  .snip-card:hover .snip-title {
    color: var(--blue);
  }
  
  .snip-desc {
    font-size: 0.74rem;
    color: var(--text-mute);
    line-height: 1.55;
    margin-bottom: 0.8rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .snip-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(241, 245, 249, 0.95);
    padding-top: 0.58rem;
    margin-top: 0.35rem;
  }
  
  .snip-lang {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 5px;
  }
  
  .lang-js  { background: #fefce8; color: #a16207; border: 1px solid #fde68a; }
  .lang-ts  { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
  .lang-py  { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
  .lang-sh  { background: #faf5ff; color: #7e22ce; border: 1px solid #e9d5ff; }
  .lang-css { background: #fdf4ff; color: #a21caf; border: 1px solid #f0abfc; }
  .lang-html{ background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
  .lang-json{ background: #f8fafc; color: #475569; border: 1px solid #e2e8f0; }
  .lang-other{ background: #f8fafc; color: var(--text-mute); border: 1px solid var(--border); }
  
  .snip-date {
    font-size: 0.62rem;
    font-family: var(--font-mono);
    color: var(--text-mute);
  }
  
  .err-msg {
    color: var(--red);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 2rem;
    text-align: center;
  }
</style>