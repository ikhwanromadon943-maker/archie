---
import Base from '../layouts/Base.astro';
---
<Base title="Home" description="A personal space for things meant to endure.">

  <!-- Hero -->
  <div class="hero-wrap">
    <div class="hero-badge-wrap">
      <span class="hero-badge">Personal Archive & Sanctuary</span>
    </div>
    <h1 class="hero-title">Archie.</h1>
    <p class="hero-sub">
      A quiet space for things meant to endure.
      Inspired by the spirit of <span class="hero-accent">Myosotis</span>—the Forget-Me-Not.
      Here, fragments of time are gathered and kept safe from the current of oblivion.
    </p>
    <div class="hero-btns">
      <a href="/notes" class="btn-primary-hero">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        Read Journal
      </a>
      <a href="/gallery" class="btn-ghost-hero">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        View Gallery
      </a>
    </div>
  </div>

  <!-- Cards -->
  <div class="home-cards">
    <a href="/notes" class="home-card">
      <div class="home-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
      </div>
      <h3>The Written Word</h3>
      <p>Fragments of thought and whispered narratives. A collection of words intended to anchor the fleeting nature of our days before they fade.</p>
    </a>
    <a href="/gallery" class="home-card">
      <div class="home-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </div>
      <h3>Visual Echoes</h3>
      <p>Frozen fractions of time. The visual traces of what once was, kept here as a testament to the beauty of the present moment.</p>
    </a>
  </div>

  <!-- Quote -->
  <div class="home-quote">
    <p class="home-quote-text">"Do not forget me when I am silent."</p>
  </div>

</Base>

<style>
  .hero-wrap {
    display:flex; flex-direction:column; align-items:center;
    justify-content:center; min-height:65vh;
    text-align:center; padding:0 1rem;
  }
  .hero-badge-wrap { margin-bottom:1.5rem; }
  .hero-badge {
    display:inline-block; padding:0.4rem 1.1rem; border-radius:999px;
    border:1px solid rgba(100,149,237,0.3); background:rgba(239,246,255,0.55);
    backdrop-filter:blur(6px); color:#6495ED;
    font-size:0.68rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase;
  }
  .hero-title {
    font-family:'Playfair Display',Georgia,serif;
    font-size:clamp(4rem,14vw,7rem); font-weight:700; color:#6495ED;
    letter-spacing:-0.04em; line-height:0.95; margin-bottom:1.25rem;
    filter:drop-shadow(0 2px 8px rgba(100,149,237,0.15));
  }
  .hero-sub {
    font-size:1.05rem; font-weight:300; color:#475569; line-height:1.85;
    max-width:480px; margin-bottom:2.75rem;
  }
  .hero-accent { color:#6495ED; font-weight:500; font-style:italic; }
  .hero-btns { display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; }
  .btn-primary-hero {
    display:inline-flex; align-items:center; gap:0.6rem;
    padding:1.05rem 2.5rem; background:#6495ED; color:#fff;
    border-radius:0.85rem; font-weight:600; font-size:1.05rem;
    box-shadow:0 8px 24px rgba(100,149,237,0.3); transition:all 0.3s ease;
  }
  .btn-primary-hero:hover { background:#5b89dc; transform:translateY(-2px); box-shadow:0 12px 28px rgba(100,149,237,0.4); }
  .btn-ghost-hero {
    display:inline-flex; align-items:center; gap:0.6rem;
    padding:1.05rem 2.5rem; background:rgba(255,255,255,0.72); backdrop-filter:blur(10px);
    border:1.5px solid rgba(255,255,255,0.85); color:#6495ED;
    border-radius:0.85rem; font-weight:600; font-size:1.05rem;
    box-shadow:0 2px 8px rgba(0,0,0,0.04); transition:all 0.3s ease;
  }
  .btn-ghost-hero:hover { background:#fff; border-color:rgba(100,149,237,0.3); transform:translateY(-2px); }
  .home-cards {
    display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin:2rem 0 3rem;
  }
  .home-card {
    background:rgba(255,255,255,0.55); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px);
    border:1px solid rgba(255,255,255,0.75); padding:2.25rem; border-radius:1.5rem;
    transition:all 0.4s ease; display:block; box-shadow:0 4px 20px rgba(100,149,237,0.06);
  }
  .home-card:hover { background:rgba(255,255,255,0.72); box-shadow:0 16px 40px rgba(100,149,237,0.1); transform:translateY(-2px); }
  .home-card-icon {
    width:46px; height:46px; background:#eff6ff; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    color:#6495ED; margin-bottom:1rem; transition:transform 0.3s ease;
  }
  .home-card:hover .home-card-icon { transform:scale(1.1); }
  .home-card h3 {
    font-family:'Playfair Display',Georgia,serif; font-size:1.3rem; font-weight:700;
    color:#334155; margin-bottom:0.6rem;
  }
  .home-card p { font-size:0.88rem; color:#64748b; line-height:1.75; font-weight:300; }
  .home-quote { text-align:center; padding:2.5rem 0; opacity:0.65; }
  .home-quote-text {
    font-family:'Playfair Display',Georgia,serif;
    font-style:italic; color:#94a3b8; font-size:0.9rem; letter-spacing:0.02em;
  }
  @media (max-width:560px) { .home-cards { grid-template-columns:1fr; } .hero-wrap { min-height:55vh; } }
</style>
