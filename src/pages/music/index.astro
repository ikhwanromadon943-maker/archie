---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

  <div class="music-page">

    <!-- TITLE -->
    <div class="music-title">ARCHIE<span class="music-dot">.</span>MUSIC</div>

    <!-- SEARCH -->
    <div class="music-search-wrap">
      <span class="music-search-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </span>
      <input type="text" id="searchInput" class="music-search-input" placeholder="Search song..." autocomplete="off"/>
      <div id="searchDropdown" class="music-search-dropdown" style="display:none"></div>
    </div>

    <!-- TRACK LIST: rendered by JS, each item = mini player card -->
    <div id="trackList" class="track-list"></div>

    <audio id="audioPlayer"></audio>

  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  const audio        = document.getElementById('audioPlayer') as HTMLAudioElement;
  const searchInput  = document.getElementById('searchInput') as HTMLInputElement;
  const searchDropdown = document.getElementById('searchDropdown') as HTMLElement;
  const trackList    = document.getElementById('trackList') as HTMLElement;

  let allTracks: any[]     = [];
  let shownTracks: any[]   = [];
  let currentTrack: any    = null;
  let isPlaying            = false;

  /* ── helpers ── */
  function fmt(sec: number) {
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function cardOf(id: any): HTMLElement | null {
    return trackList.querySelector(`.music-player[data-id="${id}"]`);
  }

  /* ── icon state ── */
  function setIcons(card: HTMLElement | null, playing: boolean) {
    if (!card) return;
    (card.querySelector('.icon-play')  as HTMLElement).style.display = playing ? 'none' : '';
    (card.querySelector('.icon-pause') as HTMLElement).style.display = playing ? ''     : 'none';
  }

  /* ── play a track ── */
  function playTrack(track: any) {
    if (!track) return;

    // deactivate previous card
    if (currentTrack) {
      const prev = cardOf(currentTrack.id);
      if (prev) {
        prev.classList.remove('is-playing');
        setIcons(prev, false);
        (prev.querySelector('.player-progress-fill') as HTMLElement).style.width = '0%';
        (prev.querySelector('.player-time') as HTMLElement).textContent = '0:00 / 0:00';
      }
    }

    currentTrack = track;

    // activate new card
    const card = cardOf(track.id);
    if (card) card.classList.add('is-playing');

    audio.src = track.url;
    audio.play()
      .then(() => { isPlaying = true;  setIcons(cardOf(track.id), true);  })
      .catch(()  => { isPlaying = false; setIcons(cardOf(track.id), false); });

    searchDropdown.style.display = 'none';
    searchInput.value = '';
  }

  /* ── toggle play/pause on current ── */
  function toggleCurrent() {
    if (!currentTrack) { if (shownTracks.length) playTrack(shownTracks[0]); return; }
    audio.paused ? audio.play() : audio.pause();
  }

  /* ── next / prev ── */
  function playNext() {
    if (!allTracks.length) return;
    const idx = allTracks.findIndex(t => t.id === currentTrack?.id);
    playTrack(allTracks[idx < allTracks.length - 1 ? idx + 1 : 0]);
  }
  function playPrev() {
    if (!allTracks.length) return;
    const idx = allTracks.findIndex(t => t.id === currentTrack?.id);
    playTrack(allTracks[idx > 0 ? idx - 1 : allTracks.length - 1]);
  }

  /* ── audio events ── */
  audio.addEventListener('timeupdate', () => {
    if (!currentTrack || !audio.duration || isNaN(audio.duration)) return;
    const card = cardOf(currentTrack.id);
    if (!card) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    (card.querySelector('.player-progress-fill') as HTMLElement).style.width = pct + '%';
    (card.querySelector('.player-time') as HTMLElement).textContent =
      fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
  });

  audio.addEventListener('loadedmetadata', () => {
    if (!currentTrack || !audio.duration || isNaN(audio.duration)) return;
    const card = cardOf(currentTrack.id);
    if (!card) return;
    (card.querySelector('.player-duration') as HTMLElement).textContent = fmt(audio.duration);
  });

  audio.addEventListener('play',  () => { isPlaying = true;  setIcons(cardOf(currentTrack?.id), true);  });
  audio.addEventListener('pause', () => { isPlaying = false; setIcons(cardOf(currentTrack?.id), false); });
  audio.addEventListener('ended', playNext);

  /* ── build one card (= one mini-player) ── */
  function buildCard(track: any, delay: number): HTMLElement {
    const hasCover = track.thumbnail &&
      (track.thumbnail.startsWith('http') || track.thumbnail.startsWith('/'));

    const div = document.createElement('div');
    // re-use all the same CSS class names from the original mini player
    div.className = 'music-player';
    div.dataset.id = String(track.id);
    div.style.animationDelay = delay + 'ms';

    div.innerHTML = `
      <!-- Thumbnail -->
      <div class="player-thumb-wrap" style="${hasCover ? '' : 'display:none'}">
        <img class="player-thumb" src="${hasCover ? track.thumbnail : ''}" alt="" loading="lazy"/>
      </div>

      <!-- Info -->
      <div class="player-info">
        <div class="player-title">${track.title || 'Unknown'}</div>
        <div class="player-artist">${track.artist || '—'}</div>
        <div class="player-duration"></div>
      </div>

      <!-- Controls -->
      <div class="player-controls">
        <button class="player-btn-sm btn-prev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
        </button>
        <button class="player-btn-play btn-play" aria-label="Play/Pause">
          <svg class="icon-play"  width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg class="icon-pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        <button class="player-btn-sm btn-next" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
        </button>
      </div>

      <!-- Progress -->
      <div class="player-progress btn-progress">
        <div class="player-progress-fill"></div>
      </div>
      <div class="player-time">0:00 / 0:00</div>
    `;

    /* button events */
    div.querySelector('.btn-play')!.addEventListener('click', e => {
      e.stopPropagation();
      currentTrack?.id === track.id ? toggleCurrent() : playTrack(track);
    });
    div.querySelector('.btn-prev')!.addEventListener('click', e => {
      e.stopPropagation();
      if (currentTrack?.id === track.id) playPrev(); else playTrack(track);
    });
    div.querySelector('.btn-next')!.addEventListener('click', e => {
      e.stopPropagation();
      if (currentTrack?.id === track.id) playNext(); else playTrack(track);
    });

    /* progress bar seek */
    const bar = div.querySelector('.btn-progress') as HTMLElement;
    bar.addEventListener('click', e => {
      e.stopPropagation();
      if (currentTrack?.id !== track.id) return;
      if (!audio.duration || isNaN(audio.duration)) return;
      const rect = bar.getBoundingClientRect();
      audio.currentTime = ((e as MouseEvent).clientX - rect.left) / rect.width * audio.duration;
    });

    return div;
  }

  /* ── render list ── */
  function renderList(list: any[]) {
    trackList.innerHTML = '';
    shownTracks = list;

    if (!list.length) {
      trackList.innerHTML = '<p class="no-tracks">No tracks found.</p>';
      return;
    }

    list.forEach((track, i) => {
      const card = buildCard(track, i * 40);
      if (currentTrack?.id === track.id) {
        card.classList.add('is-playing');
        setIcons(card, isPlaying);
      }
      trackList.appendChild(card);
    });
  }

  /* ── search ── */
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();

    if (!q) {
      searchDropdown.style.display = 'none';
      renderList(allTracks);
      return;
    }

    const hits = allTracks.filter(t =>
      t.title?.toLowerCase().includes(q) || t.artist?.toLowerCase().includes(q)
    );

    // dropdown
    if (!hits.length) {
      searchDropdown.innerHTML = '<div class="dropdown-empty">No results</div>';
    } else {
      searchDropdown.innerHTML = hits.map(t => `
        <div class="dropdown-item" data-id="${t.id}">
          <span>${t.title}</span>
          <span style="color:#94a3b8;font-size:0.75rem">${t.artist || ''}</span>
        </div>`).join('');
      searchDropdown.querySelectorAll('.dropdown-item').forEach(el => {
        el.addEventListener('click', () => {
          const track = allTracks.find(t => t.id == (el as HTMLElement).dataset.id);
          if (track) playTrack(track);
          searchInput.value = '';
          searchDropdown.style.display = 'none';
          renderList(allTracks);
        });
      });
    }
    searchDropdown.style.display = 'block';
    renderList(hits);
  });

  document.addEventListener('click', e => {
    if (!(e.target as HTMLElement).closest('.music-search-wrap'))
      searchDropdown.style.display = 'none';
  });

  /* ── init ── */
  (async () => {
    // skeleton while loading
    for (let i = 0; i < 3; i++) {
      const sk = document.createElement('div');
      sk.className = 'music-player skeleton';
      trackList.appendChild(sk);
    }

    const { data } = await supabase
      .from('music')
      .select('*')
      .order('added_at', { ascending: false });

    if (data && data.length > 0) {
      allTracks = data;
      renderList(allTracks);
    } else {
      trackList.innerHTML = '<p class="no-tracks">No tracks. Add some in the admin panel.</p>';
    }
  })();
</script>

<style>
  /* ── page ── */
  .music-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 3rem 1rem 2rem;
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* ── title ── */
  .music-title {
    text-align: center;
    font-size: clamp(2rem, 10vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1e293b;
    margin-bottom: 1.5rem;
  }
  .music-dot { color: #6495ED; }

  /* ── search ── */
  .music-search-wrap {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .music-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    z-index: 2;
    display: flex;
  }
  .music-search-input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    border: 1.5px solid #e2e8f0;
    border-radius: 50px;
    font-size: 0.875rem;
    color: #1e293b;
    background: #fff;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .music-search-input:focus {
    border-color: #6495ED;
    box-shadow: 0 0 0 3px rgba(100,149,237,0.1);
  }
  .music-search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0; right: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    max-height: 250px;
    overflow-y: auto;
    z-index: 100;
    padding: 6px;
  }
  .dropdown-item {
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: #1e293b;
    transition: background 0.15s;
  }
  .dropdown-item:hover { background: rgba(100,149,237,0.08); }
  .dropdown-empty {
    padding: 12px;
    text-align: center;
    color: #94a3b8;
    font-size: 0.8rem;
  }

  /* ── track list ── */
  .track-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* ── CARD = exact mini player styles ── */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .music-player {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    padding: 14px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    animation: cardIn 0.3s ease both;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .music-player:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.09);
  }
  .music-player.is-playing {
    border-color: #6495ED;
    box-shadow: 0 4px 20px rgba(100,149,237,0.18);
  }

  /* skeleton */
  .music-player.skeleton {
    height: 82px;
    background: linear-gradient(90deg, #f1f5f9 25%, #e8edf4 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border: none;
    box-shadow: none;
  }
  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── thumbnail ── */
  .player-thumb-wrap {
    width: 44px; height: 44px;
    min-width: 44px; max-width: 44px;
    min-height: 44px; max-height: 44px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
  }
  .player-thumb {
    width: 44px !important; height: 44px !important;
    min-width: 44px !important; max-width: 44px !important;
    min-height: 44px !important; max-height: 44px !important;
    object-fit: cover !important;
    display: block !important;
  }
  .music-player.is-playing .player-thumb-wrap {
    box-shadow: 0 0 0 2px #6495ED;
  }

  /* ── info ── */
  .player-info {
    flex: 1;
    min-width: 0;
  }
  .player-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .music-player.is-playing .player-title { color: #6495ED; }
  .player-artist {
    font-size: 0.75rem;
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .player-duration {
    font-size: 0.65rem;
    color: #94a3b8;
    font-family: monospace;
    margin-top: 2px;
  }

  /* ── controls ── */
  .player-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .player-btn-sm {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: none;
    background: #f1f5f9;
    color: #6495ED;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .player-btn-sm:hover { background: #e2e8f0; }
  .player-btn-play {
    width: 40px; height: 40px;
    border-radius: 50%;
    border: none;
    background: #6495ED;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(100,149,237,0.35);
    transition: background 0.15s, transform 0.15s;
  }
  .player-btn-play:hover { background: #5b89dc; transform: scale(1.05); }

  /* ── progress ── */
  .player-progress {
    width: 100%;
    height: 4px;
    background: #f1f5f9;
    border-radius: 10px;
    cursor: pointer;
    overflow: hidden;
  }
  .player-progress-fill {
    height: 100%;
    background: #6495ED;
    border-radius: 10px;
    width: 0%;
    transition: width 0.1s linear;
  }
  .player-time {
    width: 100%;
    font-size: 0.65rem;
    font-family: monospace;
    color: #94a3b8;
    text-align: right;
  }

  /* ── misc ── */
  .no-tracks {
    text-align: center;
    color: #94a3b8;
    font-size: 0.875rem;
    padding: 2rem 0;
  }
</style>