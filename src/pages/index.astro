---
import Base from '../layouts/Base.astro';
---
<Base title="Home" description="A personal space for things meant to endure.">

  <!-- Hero -->
  <div class="hero-wrap">
    <div class="hero-badge-wrap">
      <span class="hero-badge">Personal Archive &amp; Sanctuary</span>
    </div>
    <h1 class="hero-title">Archie.</h1>
    <p class="hero-sub">
      A quiet space for things meant to endure.
      Inspired by the spirit of <span class="hero-accent">Myosotis</span>&mdash;the Forget-Me-Not.
      Here, fragments of time are gathered and kept safe from the current of oblivion.
    </p>
    <div class="hero-btns">
      <a href="/notes" class="btn-primary-hero">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        Read Journal
      </a>
      <a href="/gallery" class="btn-ghost-hero">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        View Gallery
      </a>
    </div>
  </div>

  <!-- Cards -->
  <div class="home-cards">
    <a href="/notes" class="home-card group">
      <div class="home-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
      </div>
      <h3>The Written Word</h3>
      <p>Fragments of thought and whispered narratives. A collection of words intended to anchor the fleeting nature of our days before they fade.</p>
    </a>
    <a href="/gallery" class="home-card group">
      <div class="home-card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </div>
      <h3>Visual Echoes</h3>
      <p>Frozen fractions of time. The visual traces of what once was, kept here as a testament to the beauty of the present moment.</p>
    </a>
  </div>

  <!-- Quote -->
  <div class="home-quote">
    <p class="home-quote-text">&ldquo;Do not forget me when I am silent.&rdquo;</p>
  </div>

</Base>

<style>
  /* Hero */
  .hero-wrap {
    display:flex; flex-direction:column; align-items:center;
    justify-content:center; min-height:65vh;
    text-align:center; padding:0 1rem;
  }
  .hero-badge-wrap { margin-bottom:1.5rem; }
  .hero-badge {
    display:inline-block;
    padding:0.35rem 1rem;
    border-radius:999px;
    border:1px solid rgba(100,149,237,0.3);
    background:rgba(255,255,255,0.55);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    color:#6495ED;
    font-size:0.65rem; font-weight:700;
    letter-spacing:0.2em; text-transform:uppercase;
  }
  .hero-title {
    font-family:'Playfair Display',Georgia,serif;
    font-size:clamp(4rem,14vw,7rem);
    font-weight:700; color:#6495ED;
    letter-spacing:-0.04em; line-height:0.95;
    margin-bottom:1.25rem;
    filter:drop-shadow(0 2px 8px rgba(100,149,237,0.15));
  }
  .hero-sub {
    font-size:1rem; font-weight:300;
    color:#475569; line-height:1.85;
    max-width:480px; margin-bottom:2.5rem;
  }
  .hero-accent { color:#6495ED; font-weight:500; font-style:italic; }
  .hero-btns {
    display:flex; flex-wrap:wrap;
    gap:1rem; justify-content:center;
  }

  /* Bigger buttons with smooth click animation */
  .btn-primary-hero {
    display:inline-flex; align-items:center; gap:0.6rem;
    padding:1rem 2.25rem;
    background:#6495ED; color:#fff;
    border-radius:0.875rem; font-weight:600; font-size:1rem;
    box-shadow:0 8px 24px rgba(100,149,237,0.35);
    transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-primary-hero:hover { background:#5b89dc; transform:translateY(-3px); box-shadow:0 14px 32px rgba(100,149,237,0.45); }
  .btn-primary-hero:active { transform:scale(0.96) translateY(0); box-shadow:0 4px 12px rgba(100,149,237,0.25); transition:all 0.1s ease; }

  .btn-ghost-hero {
    display:inline-flex; align-items:center; gap:0.6rem;
    padding:1rem 2.25rem;
    background:rgba(255,255,255,0.65); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
    border:1.5px solid rgba(255,255,255,0.85);
    color:#6495ED; border-radius:0.875rem; font-weight:600; font-size:1rem;
    box-shadow:0 4px 16px rgba(0,0,0,0.05);
    transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
  }
  .btn-ghost-hero:hover { background:rgba(255,255,255,0.88); border-color:rgba(100,149,237,0.4); transform:translateY(-3px); box-shadow:0 10px 24px rgba(100,149,237,0.12); }
  .btn-ghost-hero:active { transform:scale(0.96) translateY(0); transition:all 0.1s ease; }

  /* Cards — glass morphism */
  .home-cards {
    display:grid; grid-template-columns:repeat(2,1fr);
    gap:1.25rem; margin:2rem 0 3rem;
  }
  .home-card {
    background:rgba(255,255,255,0.55);
    backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
    border:1px solid rgba(255,255,255,0.75);
    padding:1.75rem 1.5rem; border-radius:1.5rem;
    transition:all 0.3s ease; display:block;
    box-shadow:0 4px 20px rgba(100,149,237,0.07);
  }
  .home-card:hover { background:rgba(255,255,255,0.72); box-shadow:0 16px 40px rgba(100,149,237,0.12); transform:translateY(-3px); }
  .home-card:active { transform:scale(0.98); transition:all 0.1s ease; }
  .home-card-icon {
    width:42px; height:42px;
    background:#eff6ff; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    color:#6495ED; margin-bottom:1rem;
    transition:transform 0.3s ease;
  }
  .home-card:hover .home-card-icon { transform:scale(1.12); }
  .home-card h3 {
    font-family:'Playfair Display',Georgia,serif;
    font-size:1.15rem; font-weight:700;
    color:#334155; margin-bottom:0.5rem;
  }
  .home-card p { font-size:0.82rem; color:#64748b; line-height:1.75; font-weight:300; }

  /* Quote */
  .home-quote { text-align:center; padding:2.5rem 0; opacity:0.65; }
  .home-quote-text {
    font-family:'Playfair Display',Georgia,serif;
    font-style:italic; color:#94a3b8; font-size:0.9rem; letter-spacing:0.02em;
  }

  @media (max-width:560px) {
    .home-cards { grid-template-columns:1fr; }
    .hero-wrap { min-height:55vh; }
  }
</style>
