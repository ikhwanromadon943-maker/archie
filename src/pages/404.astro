---
import Base from '../layouts/Base.astro';
---
<Base title="404">
  <div class="nf-wrap fade-up">
    <p class="nf-code">404</p>
    <h1 class="nf-title">Page not found.</h1>
    <p class="nf-sub">The page you're looking for has wandered off into the void.</p>
    <a href="/" class="nf-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
      </svg>
      Return Home
    </a>
  </div>
</Base>
<style>
  .nf-wrap { display:flex; flex-direction:column; justify-content:center; min-height:60vh; gap:0.75rem; }
  .nf-code { font-family:monospace; font-size:0.7rem; color:#6495ED; letter-spacing:0.15em; }
  .nf-title { font-family:'Playfair Display',serif; font-size:clamp(2rem,7vw,4rem); font-weight:700; color:#1e293b; letter-spacing:-0.03em; line-height:1; }
  .nf-sub { font-size:0.875rem; color:#64748b; font-weight:300; }
  .nf-btn { display:inline-flex; align-items:center; gap:0.5rem; margin-top:1.5rem; padding:0.65rem 1.35rem; background:#eff6ff; color:#6495ED; border-radius:0.75rem; font-size:0.82rem; font-weight:500; transition:all 0.2s ease; border:1.5px solid rgba(100,149,237,0.2); }
  .nf-btn:hover { background:#dbeafe; transform:translateX(-2px); }
</style>
