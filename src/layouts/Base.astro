---
import '../styles/global.css';
interface Props { title?: string; description?: string; }
const { title = 'Archie', description = 'A personal space.' } = Astro.props;
const p = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? p === '/' : p.startsWith(href);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
  <meta name="description" content={description}/>
  <title>{title} · Archie</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body>

  <div class="flowers" id="flowers"></div>

  <header class="site-header">
    <a href="/" class="nav-logo">Archie<span class="logo-dot">.</span></a>
  </header>

  <main><slot /></main>

  <footer class="site-footer">&copy; {new Date().getFullYear()} Dandi</footer>

  <div class="tab-bar-outer">
    <nav class="tab-bar">
      <a href="/" class={`tab-item${isActive('/') ? ' active' : ''}`} aria-label="Home">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      <a href="/notes" class={`tab-item${isActive('/notes') ? ' active' : ''}`} aria-label="Journal">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </a>
      <a href="/gallery" class={`tab-item${isActive('/gallery') ? ' active' : ''}`} aria-label="Gallery">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </a>
      <a href="/music" class={`tab-item${isActive('/music') ? ' active' : ''}`} aria-label="Music">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      </a>
      <a href="/snippets" class={`tab-item${isActive('/snippets') ? ' active' : ''}`} aria-label="Code">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      </a>
      <a href="/vault" class={`tab-item${isActive('/vault') ? ' active' : ''}`} aria-label="Vault">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </a>
      <a href="/about" class={`tab-item${isActive('/about') ? ' active' : ''}`} aria-label="About">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </a>
      <a href="/admin/login" class={`tab-item${isActive('/admin') ? ' active' : ''}`} aria-label="Admin">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
    </nav>
  </div>

  <script>
    const FLOWER = (c1: string, c2: string) => `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40">
      <ellipse cx="20" cy="10" rx="4.8" ry="9.2" fill="${c1}" opacity="0.92" transform="rotate(0,20,20)"/>
      <ellipse cx="20" cy="10" rx="4.8" ry="9.2" fill="${c2}" opacity="0.88" transform="rotate(72,20,20)"/>
      <ellipse cx="20" cy="10" rx="4.8" ry="9.2" fill="${c1}" opacity="0.92" transform="rotate(144,20,20)"/>
      <ellipse cx="20" cy="10" rx="4.8" ry="9.2" fill="${c2}" opacity="0.88" transform="rotate(216,20,20)"/>
      <ellipse cx="20" cy="10" rx="4.8" ry="9.2" fill="${c1}" opacity="0.92" transform="rotate(288,20,20)"/>
      <circle cx="20" cy="20" r="5.5" fill="#eef5ff"/>
      <circle cx="20" cy="20" r="3" fill="#fefce8"/>
    </svg>`;

    const PETAL = (c: string) => `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 28">
      <ellipse cx="9" cy="14" rx="6" ry="12" fill="${c}" opacity="0.55"/>
    </svg>`;

    const PALETTES = [
      ['#b8d0f4','#9abde8'],['#c2d8f6','#a8c8ec'],
      ['#bdd4f5','#9ec0ea'],['#ccdaf7','#b2c9ef'],['#d4e5fb','#b8d2f2'],
    ];

    const container = document.getElementById('flowers')!;
    let activeCount = 0;
    const MAX_ACTIVE = 45;

    function spawnFlower() {
      if (activeCount >= MAX_ACTIVE) return;
      activeCount++;
      const el = document.createElement('div');
      el.className = 'petal';
      const isFlower = Math.random() > 0.35;
      const size = isFlower ? 16 + Math.random() * 18 : 8 + Math.random() * 10;
      const pal  = PALETTES[Math.floor(Math.random() * PALETTES.length)];
      const side = Math.random();
      let x: number;
      if (side < 0.60)      x = 58 + Math.random() * 40;
      else if (side < 0.82) x = 1  + Math.random() * 20;
      else                  x = 22 + Math.random() * 35;
      const dur   = 6 + Math.random() * 6;
      const delay = Math.random() * 0.6;
      const dx    = (Math.random() - 0.5) * 70;
      const rot   = Math.random() * 360;
      el.style.cssText = `left:${x}%;top:-60px;width:${size}px;height:${size}px;--dx:${dx}px;--rot:${rot}deg;animation:floatPetal ${dur}s ${delay}s linear forwards`;
      el.innerHTML = isFlower ? FLOWER(pal[0], pal[1]) : PETAL(pal[0]);
      container.appendChild(el);
      setTimeout(() => { el.remove(); activeCount--; }, (dur + delay + 0.5) * 1000);
    }

    // Burst on load then steady rain
    for (let i = 0; i < 30; i++) setTimeout(spawnFlower, i * 80);
    setInterval(spawnFlower, 380);
  </script>

</body>
</html>
