---
import Base from '../../layouts/Base.astro';
---
<Base title="Vault" description="Private notes, locked memories.">

  <!-- Locked state -->
  <div id="vault-locked" class="vault-outer">
    <div class="vault-card">
      <div class="vault-icon-circle">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#6495ED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="36" height="36">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          <circle cx="12" cy="16.5" r="1"/>
        </svg>
      </div>
      <h2 class="vault-title">Private Vault</h2>
      <p class="vault-sub">Enter access code</p>

      <!-- PIN dots -->
      <div class="pin-dots-wrap" id="pin-wrap">
        <div class="pin-dots" id="pin-dots">
          {Array.from({length:8}).map((_,i) => <div class="pin-dot" id={`d${i}`}></div>)}
        </div>
        <input type="password" id="vault-pw" class="vault-input" autocomplete="off" maxlength="32"/>
      </div>

      <p class="vault-error" id="vault-error"></p>

      <button class="vault-unlock-btn" id="vault-unlock">UNLOCK</button>
    </div>
  </div>

  <!-- Unlocked state -->
  <div id="vault-content" style="display:none">
    <div class="page-hdr-row">
      <div>
        <h1 class="vault-unlocked-title">My Vault</h1>
        <p class="vault-unlocked-sub">Private entries, visible only to you.</p>
      </div>
      <button class="vault-lock-btn" id="vault-lock">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Lock
      </button>
    </div>
    <div class="loading-state" id="vault-loading" style="display:none"><span class="loader"></span></div>
    <div id="vault-list" class="notes-grid"></div>
    <div class="empty-state" id="vault-empty" style="display:none">
      <div class="empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h3>Nothing here yet.</h3>
      <p>Add private entries from the admin panel.</p>
    </div>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';
  const SESSION_KEY = 'vault_unlocked';
  const fdate = (iso: string) => new Date(iso).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});

  let pinValue = '';
  const pwInput = document.getElementById('vault-pw') as HTMLInputElement;

  function updateDots() {
    for (let i = 0; i < 8; i++) {
      document.getElementById(`d${i}`)!.classList.toggle('filled', i < pinValue.length);
    }
  }

  document.getElementById('pin-wrap')!.addEventListener('click', () => pwInput.focus());
  pwInput.addEventListener('input', function() { pinValue = this.value; updateDots(); });
  pwInput.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key==='Enter') document.getElementById('vault-unlock')!.click(); });

  async function getPass(): Promise<string> {
    const { data } = await supabase.from('settings').select('value').eq('key','admin_pass').single();
    return data?.value || 'mysite2025';
  }

  async function renderVault() {
    const vl = document.getElementById('vault-loading')!;
    const list = document.getElementById('vault-list')!;
    const empty = document.getElementById('vault-empty')!;
    vl.style.display='flex'; list.innerHTML='';
    const { data: items, error } = await supabase.from('vault').select('*').order('created_at',{ascending:false});
    vl.style.display='none';
    if (error || !items?.length) { empty.style.display='block'; return; }
    empty.style.display='none';
    items.forEach((item: any, i: number) => {
      const el = document.createElement('article');
      el.className = 'note-card';
      el.style.cssText = `opacity:0;animation:fadeUp 0.4s ease ${i*0.07}s forwards`;
      el.innerHTML = `
        <div class="note-card-body">
          <div class="note-meta-row">
            <div class="note-meta-left">
              <span class="note-dot"></span>
              <span class="note-date">${fdate(item.created_at)}</span>
            </div>
          </div>
          <h2 class="note-title">${item.title}</h2>
          <p class="note-body" style="-webkit-line-clamp:unset;overflow:visible">${item.content.replace(/\n/g,'<br>')}</p>
        </div>`;
      list.appendChild(el);
    });
  }

  function unlock() {
    document.getElementById('vault-locked')!.style.display='none';
    document.getElementById('vault-content')!.style.display='block';
    renderVault();
  }

  if (sessionStorage.getItem(SESSION_KEY)==='1') unlock();

  document.getElementById('vault-unlock')!.addEventListener('click', async () => {
    const err = document.getElementById('vault-error')!;
    const correct = await getPass();
    if (pinValue === correct) {
      sessionStorage.setItem(SESSION_KEY,'1'); err.textContent=''; unlock();
    } else {
      err.textContent='Wrong access code.';
      pinValue=''; pwInput.value=''; updateDots();
      const dots = document.getElementById('pin-dots')!;
      dots.classList.add('shake');
      setTimeout(()=>dots.classList.remove('shake'),400);
    }
  });

  document.getElementById('vault-lock')?.addEventListener('click',()=>{ sessionStorage.removeItem(SESSION_KEY); location.reload(); });
</script>
