---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

  <div class="music-hero">
    <h1 class="music-big-title">ARCHIE<span class="music-dot">.</span>MUSIC</h1>
    <div class="music-search-row">
      <div class="music-search-wrap">
        <div class="music-search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <input type="text" id="music-search" class="music-search-input" placeholder="Search song..."/>
      </div>
    </div>
  </div>

  <!-- DAFTAR SEMUA LAGU -->
  <div class="track-list" id="track-list">
    <!-- di-render oleh JS -->
  </div>

  <!-- Mini player - selalu muncul -->
  <div class="mini-player" id="mini-player">
    <img class="mp-thumb" id="mp-thumb" src="" alt="" style="display:none"/>
    <div class="mp-info">
      <div class="mp-title" id="mp-title">Press play to start</div>
      <div class="mp-artist" id="mp-artist">—</div>
    </div>
    <div class="mp-controls">
      <button class="mp-play-btn" id="mp-play">
        <svg id="mp-play-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        <svg id="mp-pause-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      </button>
    </div>
    <div class="mp-progress-wrap" id="mp-progress-wrap">
      <div class="mp-progress-bg"><div class="mp-progress-fill" id="mp-fill"></div></div>
      <span class="mp-time" id="mp-time">0:00</span>
    </div>
  </div>

  <audio id="audio-player"></audio>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  let allTracks: any[] = [];
  let currentIdx = -1;
  let isPlaying = false;

  const audio = document.getElementById('audio-player') as HTMLAudioElement;
  const mpTitle = document.getElementById('mp-title')!;
  const mpArtist = document.getElementById('mp-artist')!;
  const mpThumb = document.getElementById('mp-thumb') as HTMLImageElement;
  const mpFill = document.getElementById('mp-fill')!;
  const mpTime = document.getElementById('mp-time')!;
  const playIcon = document.getElementById('mp-play-icon')!;
  const pauseIcon = document.getElementById('mp-pause-icon')!;
  const trackList = document.getElementById('track-list')!;
  const searchInput = document.getElementById('music-search') as HTMLInputElement;

  function formatTime(s: number) {
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  function setUI(playing: boolean) {
    isPlaying = playing;
    playIcon.style.display = playing ? 'none' : '';
    pauseIcon.style.display = playing ? '' : 'none';
  }

  function highlightActiveTrack(idx: number) {
    document.querySelectorAll('.track-item').forEach((el, i) => {
      el.classList.toggle('active', i === idx);
    });
  }

  function loadTrack(idx: number) {
    const t = allTracks[idx];
    if (!t) return;
    currentIdx = idx;
    mpTitle.textContent = t.title;
    mpArtist.textContent = t.artist;
    if (t.thumbnail) {
      mpThumb.src = t.thumbnail;
      mpThumb.style.display = '';
    } else {
      mpThumb.style.display = 'none';
    }
    mpFill.style.width = '0%';
    mpTime.textContent = '0:00';
    highlightActiveTrack(idx);

    if (t.url) {
      audio.src = t.url;
      audio.play().then(() => setUI(true)).catch(() => setUI(false));
    }
  }

  audio.addEventListener('timeupdate', () => {
    if (!audio.duration) return;
    mpFill.style.width = (audio.currentTime / audio.duration) * 100 + '%';
    mpTime.textContent = formatTime(audio.currentTime) + ' / ' + formatTime(audio.duration);
  });

  audio.addEventListener('play', () => setUI(true));
  audio.addEventListener('pause', () => setUI(false));
  audio.addEventListener('ended', () => {
    if (currentIdx < allTracks.length - 1) loadTrack(currentIdx + 1);
    else setUI(false);
  });

  document.getElementById('mp-play')!.addEventListener('click', () => {
    if (allTracks.length === 0) return;
    if (currentIdx === -1) loadTrack(0);
    else if (audio.paused) audio.play();
    else audio.pause();
  });

  document.getElementById('mp-progress-wrap')!.addEventListener('click', (e) => {
    if (!audio.duration) return;
    const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
    audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
  });

  // Search filter
  searchInput.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase();
    renderTrackList(query);
  });

  function renderTrackList(filter: string = '') {
    const filtered = allTracks.filter(t =>
      t.title.toLowerCase().includes(filter) || t.artist.toLowerCase().includes(filter)
    );
    trackList.innerHTML = filtered.map((t, i) => {
      const realIdx = allTracks.indexOf(t);
      return `
        <div class="track-item ${realIdx === currentIdx ? 'active' : ''}" data-index="${realIdx}">
          <div class="track-item-thumb">
            ${t.thumbnail ? `<img src="${t.thumbnail}" alt="${t.title}"/>` : `<div class="track-item-no-thumb">🎵</div>`}
          </div>
          <div class="track-item-info">
            <div class="track-item-title">${t.title}</div>
            <div class="track-item-artist">${t.artist}</div>
          </div>
          <button class="track-item-play" data-index="${realIdx}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
      `;
    }).join('');

    // Attach click events
    document.querySelectorAll('.track-item').forEach(el => {
      el.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button');
        const idx = parseInt((btn || el as HTMLElement).getAttribute('data-index') || '0');
        if (idx === currentIdx) {
          // Toggle play/pause
          if (audio.paused) audio.play(); else audio.pause();
        } else {
          loadTrack(idx);
        }
      });
    });
  }

  // Load tracks dari Supabase
  (async () => {
    const { data, error } = await supabase.from('music').select('*').order('added_at', { ascending: false });
    if (data && data.length > 0) {
      allTracks.push(...data);
      mpTitle.textContent = data.length + ' tracks loaded';
      mpArtist.textContent = 'Click a song to play';
      renderTrackList();
    } else {
      mpTitle.textContent = 'No tracks found';
      mpArtist.textContent = 'Add tracks in admin panel';
      trackList.innerHTML = '<p class="no-tracks">No tracks available. Add them in the admin panel.</p>';
    }
  })();
</script>

<style>
  .music-hero { text-align: center; padding: 3rem 0 1rem; }
  .music-big-title { font-family: 'Inter', system-ui, sans-serif; font-size: clamp(2.5rem, 11vw, 4.2rem); font-weight: 700; letter-spacing: -0.02em; color: #1e293b; margin-bottom: 2rem; line-height: 1; }
  .music-dot { color: #6495ED; }
  .music-search-row { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto 2rem; }
  .music-search-wrap { flex: 1; position: relative; }
  .music-search-icon { position: absolute; left: 0.9rem; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none; display: flex; }
  .music-search-input { width: 100%; background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border: 1.5px solid rgba(255,255,255,0.85); border-radius: 999px; padding: 0.7rem 1rem 0.7rem 2.5rem; font-size: 0.875rem; color: #1e293b; outline: none; }
  .music-search-input:focus { border-color: #6495ED; box-shadow: 0 0 0 3px rgba(100,149,237,0.12); }

  /* Track List */
  .track-list {
    max-width: 420px;
    margin: 0 auto 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .track-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.65);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 14px;
    padding: 0.65rem 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .track-item:hover {
    background: rgba(100,149,237,0.08);
    border-color: rgba(100,149,237,0.25);
  }
  .track-item.active {
    background: rgba(100,149,237,0.12);
    border-color: #6495ED;
    box-shadow: 0 0 0 2px rgba(100,149,237,0.15);
  }
  .track-item-thumb {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .track-item-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .track-item-no-thumb {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(100,149,237,0.1);
    font-size: 1.2rem;
  }
  .track-item-info {
    flex: 1;
    min-width: 0;
  }
  .track-item-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .track-item-artist {
    font-size: 0.7rem;
    color: #94a3b8;
  }
  .track-item-play {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(100,149,237,0.1);
    color: #6495ED;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .track-item-play:hover {
    background: #6495ED;
    color: #fff;
  }
  .no-tracks {
    text-align: center;
    color: #94a3b8;
    font-size: 0.875rem;
    padding: 2rem;
  }

  /* Mini Player */
  .mini-player {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: 18px;
    padding: 0.85rem 1rem;
    margin: 0 auto;
    max-width: 420px;
    box-shadow: 0 4px 20px rgba(100,149,237,0.1);
  }
  .mp-thumb { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; flex-shrink: 0; }
  .mp-info { flex: 1; min-width: 0; }
  .mp-title { font-size: 0.875rem; font-weight: 600; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mp-artist { font-size: 0.7rem; color: #94a3b8; }
  .mp-controls { display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0; }
  .mp-play-btn { display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: #6495ED; color: #fff; border: none; cursor: pointer; box-shadow: 0 4px 12px rgba(100,149,237,0.35); }
  .mp-play-btn:hover { background: #5b89dc; transform: scale(1.06); }
  .mp-progress-wrap { width: 100%; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; }
  .mp-progress-bg { flex: 1; height: 4px; background: rgba(100,149,237,0.15); border-radius: 999px; overflow: hidden; }
  .mp-progress-fill { height: 100%; background: #6495ED; border-radius: 999px; width: 0%; }
  .mp-time { font-size: 0.6rem; font-family: monospace; color: #94a3b8; flex-shrink: 0; white-space: nowrap; }
</style>