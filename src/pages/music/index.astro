---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

  <div class="music-page">
    <!-- TITLE -->
    <div class="music-title">ARCHIE<span class="music-dot">.</span>MUSIC</div>

    <!-- SEARCH -->
    <div class="music-search-row">
      <div class="music-search-icon-big">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6495ED" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
      <div class="music-search-wrap">
        <input type="text" id="searchInput" class="music-search-input" placeholder="Search song..." autocomplete="off"/>
        <div id="searchDropdown" class="music-search-dropdown" style="display:none"></div>
      </div>
    </div>

    <!-- MINI PLAYER -->
    <div class="music-player" id="musicPlayer">
      <div id="playerThumbWrap" class="player-thumb-wrap" style="display:none">
        <img id="playerThumb" class="player-thumb" src="" alt=""/>
      </div>
      <div class="player-info">
        <div id="playerTitle" class="player-title">Press play</div>
        <div id="playerArtist" class="player-artist">—</div>
        <div id="playerDuration" class="player-duration"></div>
      </div>
      <div class="player-controls">
        <button id="btnPrev" class="player-btn-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
        </button>
        <button id="btnPlay" class="player-btn-play">
          <svg id="iconPlay" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg id="iconPause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        <button id="btnNext" class="player-btn-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
        </button>
      </div>
      <div id="progressBar" class="player-progress">
        <div id="progressFill" class="player-progress-fill"></div>
      </div>
      <div id="timeDisplay" class="player-time">0:00 / 0:00</div>
    </div>

    <!-- TRACKS LIST -->
    <div id="tracksList" class="tracks-list"></div>

    <audio id="audioPlayer"></audio>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  const audio = document.getElementById('audioPlayer') as HTMLAudioElement;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchDropdown = document.getElementById('searchDropdown')!;
  const playerTitle = document.getElementById('playerTitle')!;
  const playerArtist = document.getElementById('playerArtist')!;
  const playerDuration = document.getElementById('playerDuration')!;
  const playerThumb = document.getElementById('playerThumb') as HTMLImageElement;
  const playerThumbWrap = document.getElementById('playerThumbWrap')!;
  const progressFill = document.getElementById('progressFill')!;
  const progressBar = document.getElementById('progressBar')!;
  const timeDisplay = document.getElementById('timeDisplay')!;
  const iconPlay = document.getElementById('iconPlay')!;
  const iconPause = document.getElementById('iconPause')!;
  const tracksList = document.getElementById('tracksList')!;

  let tracks: any[] = [];
  let currentTrack: any = null;
  let isPlaying = false;

  function fmt(sec: number): string {
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function updatePlayIcon(playing: boolean) {
    isPlaying = playing;
    iconPlay.style.display = playing ? 'none' : '';
    iconPause.style.display = playing ? '' : 'none';
  }

  function highlightActiveTrack(trackId: string | null) {
    document.querySelectorAll('.track-item').forEach(el => {
      el.classList.toggle('active', (el as HTMLElement).dataset.id === trackId);
    });
    // Update icon play/pause di track yang aktif
    document.querySelectorAll('.track-item-play-icon').forEach(icon => {
      const parent = icon.closest('.track-item') as HTMLElement;
      if (parent && parent.dataset.id === trackId && isPlaying) {
        icon.innerHTML = '<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>';
      } else {
        icon.innerHTML = '<path d="M8 5v14l11-7z"/>';
      }
    });
  }

  function playTrack(track: any) {
    if (!track) return;
    currentTrack = track;

    playerTitle.textContent = track.title || 'Unknown';
    playerArtist.textContent = track.artist || '—';
    playerDuration.textContent = '';

    if (track.thumbnail && (track.thumbnail.startsWith('http') || track.thumbnail.startsWith('/'))) {
      playerThumb.src = track.thumbnail;
      playerThumbWrap.style.display = '';
    } else {
      playerThumbWrap.style.display = 'none';
    }

    highlightActiveTrack(track.id);

    audio.src = track.url;
    audio.play().then(() => updatePlayIcon(true)).catch(() => updatePlayIcon(false));

    searchDropdown.style.display = 'none';
    searchInput.value = '';
  }

  function togglePlay() {
    if (!currentTrack && tracks.length > 0) {
      playTrack(tracks[0]);
      return;
    }
    if (audio.paused) audio.play();
    else audio.pause();
  }

  function playNext() {
    if (tracks.length === 0) return;
    const idx = tracks.findIndex(t => t.id === currentTrack?.id);
    const next = idx < tracks.length - 1 ? tracks[idx + 1] : tracks[0];
    playTrack(next);
  }

  function playPrev() {
    if (tracks.length === 0) return;
    const idx = tracks.findIndex(t => t.id === currentTrack?.id);
    const prev = idx > 0 ? tracks[idx - 1] : tracks[tracks.length - 1];
    playTrack(prev);
  }

  function renderAllTracks() {
    if (tracks.length === 0) {
      tracksList.innerHTML = '';
      return;
    }

    tracksList.innerHTML = tracks.map(t => `
      <div class="track-item" data-id="${t.id}">
        <div class="track-item-thumb">
          ${t.thumbnail 
            ? `<img src="${t.thumbnail}" alt="" onerror="this.style.display='none'; this.nextElementSibling.style.display='';"/>`
            : ''}
          <svg class="track-item-thumb-placeholder" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" style="${t.thumbnail ? 'display:none' : ''}"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <div class="track-item-info">
          <div class="track-item-title">${t.title}</div>
          <div class="track-item-artist">${t.artist}</div>
        </div>
        <button class="track-item-btn" data-id="${t.id}">
          <svg class="track-item-play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>
    `).join('');

    // Click handlers
    tracksList.querySelectorAll('.track-item').forEach(row => {
      row.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('button')) return;
        const id = (row as HTMLElement).dataset.id;
        const track = tracks.find(t => t.id == id);
        if (track) {
          if (currentTrack?.id === track.id) {
            audio.paused ? audio.play() : audio.pause();
          } else {
            playTrack(track);
          }
        }
      });
    });

    tracksList.querySelectorAll('.track-item-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id;
        const track = tracks.find(t => t.id == id);
        if (track) {
          if (currentTrack?.id === track.id) {
            audio.paused ? audio.play() : audio.pause();
          } else {
            playTrack(track);
          }
        }
      });
    });
  }

  audio.addEventListener('timeupdate', () => {
    if (!audio.duration || isNaN(audio.duration)) return;
    progressFill.style.width = (audio.currentTime / audio.duration) * 100 + '%';
    timeDisplay.textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
  });

  audio.addEventListener('loadedmetadata', () => {
    if (audio.duration && !isNaN(audio.duration)) {
      playerDuration.textContent = fmt(audio.duration);
    }
  });

  audio.addEventListener('play', () => {
    updatePlayIcon(true);
    highlightActiveTrack(currentTrack?.id);
  });
  audio.addEventListener('pause', () => {
    updatePlayIcon(false);
    highlightActiveTrack(currentTrack?.id);
  });
  audio.addEventListener('ended', playNext);

  progressBar.addEventListener('click', (e) => {
    if (!audio.duration || isNaN(audio.duration)) return;
    const rect = progressBar.getBoundingClientRect();
    audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
  });

  document.getElementById('btnPlay')!.addEventListener('click', togglePlay);
  document.getElementById('btnNext')!.addEventListener('click', playNext);
  document.getElementById('btnPrev')!.addEventListener('click', playPrev);

  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    if (!q) {
      searchDropdown.style.display = 'none';
      return;
    }
    const filtered = tracks.filter(t =>
      t.title?.toLowerCase().includes(q) || t.artist?.toLowerCase().includes(q)
    );
    if (filtered.length === 0) {
      searchDropdown.innerHTML = '<div class="dropdown-empty">No results</div>';
    } else {
      searchDropdown.innerHTML = filtered.map(t => `
        <div class="dropdown-item" data-id="${t.id}">
          <span>${t.title}</span>
          <span class="dropdown-artist">${t.artist}</span>
        </div>
      `).join('');
      searchDropdown.querySelectorAll('.dropdown-item').forEach(el => {
        el.addEventListener('click', () => {
          const id = (el as HTMLElement).dataset.id;
          const track = tracks.find(t => t.id == id);
          if (track) playTrack(track);
        });
      });
    }
    searchDropdown.style.display = 'block';
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.music-search-wrap')) {
      searchDropdown.style.display = 'none';
    }
  });

  (async () => {
    const { data, error } = await supabase.from('music').select('*').order('added_at', { ascending: false });
    if (data && data.length > 0) {
      tracks = data;
      renderAllTracks();
    } else {
      playerTitle.textContent = 'No tracks';
      playerArtist.textContent = 'Add in admin panel';
    }
  })();
</script>

<style>
  .music-page {
    max-width: 440px;
    margin: 0 auto;
    padding: 3rem 1rem 2rem;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .music-title {
    text-align: center;
    font-size: clamp(2rem, 10vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1e293b;
    margin-bottom: 1.5rem;
  }
  .music-dot { color: #6495ED; }

  /* SEARCH ROW */
  .music-search-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
  }
  .music-search-icon-big {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 50%;
    background: rgba(100,149,237,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .music-search-wrap {
    flex: 1;
    position: relative;
  }
  .music-search-input {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #e2e8f0;
    border-radius: 50px;
    font-size: 0.875rem;
    color: #1e293b;
    background: #fff;
    outline: none;
    transition: border-color 0.2s;
  }
  .music-search-input:focus {
    border-color: #6495ED;
    box-shadow: 0 0 0 3px rgba(100,149,237,0.1);
  }
  .music-search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    max-height: 250px;
    overflow-y: auto;
    z-index: 100;
    padding: 6px;
  }
  .dropdown-item {
    padding: 10px 14px;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: #1e293b;
    transition: background 0.15s;
  }
  .dropdown-item:hover {
    background: rgba(100,149,237,0.08);
  }
  .dropdown-artist {
    color: #94a3b8;
    font-size: 0.75rem;
  }
  .dropdown-empty {
    padding: 12px;
    text-align: center;
    color: #94a3b8;
    font-size: 0.8rem;
  }

  /* PLAYER */
  .music-player {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    padding: 14px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    margin-bottom: 1rem;
  }
  .player-thumb-wrap {
    width: 44px;
    height: 44px;
    min-width: 44px;
    max-width: 44px;
    min-height: 44px;
    max-height: 44px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
  }
  .player-thumb {
    width: 44px !important;
    height: 44px !important;
    min-width: 44px !important;
    max-width: 44px !important;
    min-height: 44px !important;
    max-height: 44px !important;
    object-fit: cover !important;
    display: block !important;
  }
  .player-info {
    flex: 1;
    min-width: 0;
  }
  .player-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .player-artist {
    font-size: 0.75rem;
    color: #94a3b8;
  }
  .player-duration {
    font-size: 0.65rem;
    color: #94a3b8;
    font-family: monospace;
    margin-top: 2px;
  }
  .player-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .player-btn-sm {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: #f1f5f9;
    color: #6495ED;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .player-btn-sm:hover { background: #e2e8f0; }
  .player-btn-play {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: #6495ED;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(100,149,237,0.35);
  }
  .player-btn-play:hover { background: #5b89dc; transform: scale(1.05); }
  .player-progress {
    width: 100%;
    height: 4px;
    background: #f1f5f9;
    border-radius: 10px;
    cursor: pointer;
    overflow: hidden;
  }
  .player-progress-fill {
    height: 100%;
    background: #6495ED;
    border-radius: 10px;
    width: 0%;
    transition: width 0.1s linear;
  }
  .player-time {
    width: 100%;
    font-size: 0.65rem;
    font-family: monospace;
    color: #94a3b8;
    text-align: right;
  }

  /* TRACKS LIST */
  .tracks-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 0.5rem;
  }
  .track-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .track-item:hover {
    background: rgba(100,149,237,0.05);
  }
  .track-item.active {
    background: rgba(100,149,237,0.1);
  }
  .track-item.active .track-item-title {
    color: #6495ED;
  }
  .track-item-thumb {
    width: 36px;
    height: 36px;
    min-width: 36px;
    max-width: 36px;
    min-height: 36px;
    max-height: 36px;
    border-radius: 8px;
    overflow: hidden;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
  }
  .track-item-thumb img {
    width: 36px !important;
    height: 36px !important;
    min-width: 36px !important;
    max-width: 36px !important;
    object-fit: cover !important;
    position: absolute;
    inset: 0;
  }
  .track-item-info {
    flex: 1;
    min-width: 0;
  }
  .track-item-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .track-item-artist {
    font-size: 0.7rem;
    color: #94a3b8;
  }
  .track-item-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: #6495ED;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s, background 0.15s;
  }
  .track-item:hover .track-item-btn,
  .track-item.active .track-item-btn {
    opacity: 1;
  }
  .track-item-btn:hover {
    background: rgba(100,149,237,0.12);
  }
</style>