---
import Base from '../../layouts/Base.astro';
---
<Base title="Login">
  <div class="login-outer">
    <div class="login-card">
      <div class="login-deco-1"></div>
      <div class="login-deco-2"></div>
      <div class="login-inner">
        <div class="login-icon-wrap">
          <div class="login-icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#6495ED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              <circle cx="12" cy="16.5" r="1"/>
            </svg>
          </div>
        </div>
        <h2 class="login-title">Owner Login</h2>
        <p class="login-eyebrow">RESTRICTED AREA · OWNER ONLY</p>

        <div id="login-error" class="login-error">Wrong passphrase. Try again.</div>

        <div class="login-field">
          <label class="login-label">SECRET PASSPHRASE</label>
          <div class="login-input-wrap">
            <div class="login-input-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 19l-1 1-1-1-2-2-2-2 1-1-1-1 3.586-3.586A6 6 0 0120 13V9a2 2 0 012-2h-2z"/>
              </svg>
            </div>
            <input type="password" id="login-pw" class="login-input" placeholder="••••••••" autocomplete="current-password"/>
          </div>
        </div>

        <button class="login-btn" id="login-btn">
          <span id="login-btn-text">Unlock Journal</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>

        <div class="login-back-wrap">
          <a href="/" class="login-back">Return to Home</a>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '../../lib/supabase';
  if (sessionStorage.getItem('admin_authed')==='1') window.location.href='/admin';

  async function getPass(): Promise<string> {
    const { data } = await supabase.from('settings').select('value').eq('key','admin_pass').single();
    return data?.value || 'mysite2025';
  }

  document.getElementById('login-btn')!.addEventListener('click', async () => {
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const txt = document.getElementById('login-btn-text')!;
    const pw = (document.getElementById('login-pw') as HTMLInputElement).value;
    const err = document.getElementById('login-error')!;
    btn.disabled=true; txt.textContent='Checking...';
    const correct = await getPass();
    if (pw===correct) {
      sessionStorage.setItem('admin_authed','1');
      window.location.href='/admin';
    } else {
      err.classList.add('show');
      btn.disabled=false; txt.textContent='Unlock Journal';
      (document.getElementById('login-pw') as HTMLInputElement).value='';
    }
  });
  document.getElementById('login-pw')!.addEventListener('keydown',(e)=>{ if((e as KeyboardEvent).key==='Enter') document.getElementById('login-btn')!.click(); });
</script>

<style>
  .login-outer {
    display:flex; align-items:center; justify-content:center;
    min-height:75vh; padding:1rem;
  }
  .login-card {
    background:rgba(255,255,255,0.72);
    backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
    border:1px solid rgba(255,255,255,0.85);
    border-radius:2rem;
    /* lebih lebar, tidak memanjang ke bawah */
    padding:2.2rem 2.8rem;
    width:100%; max-width:520px;
    position:relative; overflow:hidden;
    box-shadow:0 25px 60px rgba(100,149,237,0.12), 0 4px 16px rgba(0,0,0,0.06);
  }
  .login-deco-1 {
    position:absolute; top:-80px; right:-80px;
    width:240px; height:240px;
    background:rgba(100,149,237,0.15); border-radius:50%;
    filter:blur(60px); pointer-events:none;
  }
  .login-deco-2 {
    position:absolute; bottom:-80px; left:-80px;
    width:240px; height:240px;
    background:rgba(180,160,220,0.12); border-radius:50%;
    filter:blur(60px); pointer-events:none;
  }
  .login-inner { position:relative; z-index:1; text-align:center; }

  .login-icon-wrap { display:flex; justify-content:center; margin-bottom:1.2rem; }
  .login-icon-circle {
    padding:1.1rem;
    background:linear-gradient(135deg,#eff6ff,#fff);
    border-radius:50%; border:1px solid #dbeafe;
    box-shadow:0 2px 12px rgba(100,149,237,0.12);
    display:flex; align-items:center; justify-content:center;
    transition:transform 0.5s ease;
  }
  .login-card:hover .login-icon-circle { transform:scale(1.08); }

  .login-title {
    font-family:'Playfair Display',serif;
    font-size:1.8rem; font-weight:700;
    color:#6495ED; margin-bottom:0.3rem; letter-spacing:-0.02em;
  }
  .login-eyebrow {
    font-size:0.62rem; font-family:monospace;
    color:#94a3b8; letter-spacing:0.2em; font-weight:600;
    margin-bottom:1.5rem; display:block;
  }

  .login-error {
    background:#fef2f2; border:1px solid #fecaca; color:#ef4444;
    padding:0.55rem 0.8rem; border-radius:0.6rem;
    font-size:0.75rem; font-family:monospace;
    margin-bottom:1rem; display:none; text-align:left;
  }
  .login-error.show { display:block; }

  .login-field { text-align:left; margin-bottom:1.25rem; }
  .login-label {
    font-size:0.6rem; font-family:monospace; font-weight:700;
    color:#94a3b8; letter-spacing:0.2em;
    display:block; margin-bottom:0.5rem; margin-left:0.75rem;
    text-transform:uppercase;
  }
  .login-input-wrap { position:relative; }
  .login-input-icon {
    position:absolute; left:1rem; top:50%; transform:translateY(-50%);
    color:#94a3b8; pointer-events:none; display:flex;
  }
  .login-input {
    width:100%; background:rgba(255,255,255,0.6);
    border:1px solid #e2e8f0; border-radius:0.75rem;
    padding:0.9rem 1rem 0.9rem 3rem;
    text-align:center; letter-spacing:0.4em;
    font-weight:700; color:#334155; font-size:0.9rem;
    outline:none; transition:all 0.3s ease;
    box-shadow:0 1px 4px rgba(0,0,0,0.04);
  }
  .login-input:focus {
    box-shadow:0 0 0 2px rgba(100,149,237,0.3);
    border-color:rgba(100,149,237,0.5);
    background:#fff;
  }
  .login-btn {
    width:100%; padding:0.9rem;
    background:#6495ED; color:#fff; border:none;
    border-radius:0.75rem;
    font-size:0.72rem; font-weight:700;
    letter-spacing:0.15em; text-transform:uppercase;
    cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.75rem;
    box-shadow:0 4px 16px rgba(100,149,237,0.3);
    transition:all 0.3s ease; margin-bottom:1.5rem;
  }
  .login-btn:hover { background:#5b89dc; transform:translateY(-2px); box-shadow:0 8px 24px rgba(100,149,237,0.4); }
  .login-btn:active { transform:scale(0.98); }
  .login-btn:disabled { opacity:0.7; cursor:not-allowed; transform:none; }

  .login-back-wrap { display:flex; justify-content:center; }
  .login-back {
    font-size:0.78rem; color:#94a3b8;
    border-bottom:1px solid transparent;
    transition:all 0.2s ease; padding-bottom:1px;
  }
  .login-back:hover { color:#6495ED; border-color:#6495ED; }
</style>
