---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Search and discover music.">

  <div class="music-hero">
    <h1 class="music-big-title">ARCHIE<span class="music-dot">.</span>MUSIC</h1>
    <div class="music-search-row">
      <div class="music-search-wrap">
        <div class="music-search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </div>
        <input type="text" id="music-search" class="music-search-input" placeholder="Search song..."/>
      </div>
      <button id="music-search-btn" class="music-search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Visualizer bar - muncul saat track dipilih -->
  <div class="music-visualizer" id="music-viz" style="display:none">
    <div class="viz-bars">
      <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
      <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
      <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
      <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
    </div>
    <div class="viz-text" id="viz-track-name">—</div>
  </div>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div id="music-list"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
      </svg>
    </div>
    <h3>START BY SEARCHING A SONG</h3>
    <p>Or add tracks via the admin panel.</p>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';
  let allTracks = [];
  let activeCard = null;

  const escapeHtml = (str) => {
    if (!str) return '';
    return str.replace(/[&<>]/g, (m) => m === '&' ? '&amp;' : m === '<' ? '&lt;' : '&gt;');
  };

  async function loadTracks() {
    const loading = document.getElementById('loading');
    const empty = document.getElementById('empty-state');
    if (!loading || !empty) return;

    const { data: items, error } = await supabase.from('music').select('*').order('added_at',{ascending:false});
    loading.style.display = 'none';
    if (error || !items?.length) { empty.style.display='block'; return; }
    allTracks = items;
    renderTracks(items);
  }

  function renderTracks(items) {
    const list = document.getElementById('music-list');
    const empty = document.getElementById('empty-state');
    if (!list || !empty) return;

    list.innerHTML = '';
    if (!items.length) { empty.style.display='block'; return; }
    empty.style.display = 'none';

    items.forEach((item, i) => {
      const escapedTitle = escapeHtml(item.title);
      const escapedArtist = escapeHtml(item.artist);
      const escapedThumb = item.thumbnail ? escapeHtml(item.thumbnail) : '';
      const escapedUrl = item.url ? escapeHtml(item.url) : '';

      const card = document.createElement('div');
      card.className = 'music-card';
      card.style.cssText = `opacity:0;animation:fadeUp 0.4s ease ${i*0.05}s forwards`;
      card.innerHTML = `
        ${item.thumbnail
          ? `<img class="music-thumb" src="${escapedThumb}" alt="${escapedTitle}" loading="lazy"/>`
          : `<div class="music-thumb-ph">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
              </svg>
            </div>`}
        <div class="music-info">
          <div class="music-name">${escapedTitle}</div>
          <div class="music-artist">${escapedArtist}</div>
        </div>
        <div class="music-duration">${item.duration||'—'}</div>
        ${item.url ? `<a href="${escapedUrl}" target="_blank" rel="noopener noreferrer" class="music-link" title="Open" onclick="event.stopPropagation()">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>` : ''}`;

      card.addEventListener('click', () => {
        const viz = document.getElementById('music-viz');
        const vizTrack = document.getElementById('viz-track-name');
        if (!viz || !vizTrack) return;

        if (activeCard === card) {
          card.classList.remove('playing');
          activeCard = null;
          viz.style.display = 'none';
        } else {
          if (activeCard) activeCard.classList.remove('playing');
          card.classList.add('playing');
          activeCard = card;
          vizTrack.textContent = `${item.title} — ${item.artist}`;
          viz.style.display = 'flex';
        }
      });

      list.appendChild(card);
    });
  }

  loadTracks();

  const searchInput = document.getElementById('music-search');
  const searchBtn = document.getElementById('music-search-btn');

  const doSearch = () => {
    if (!searchInput) return;
    const q = searchInput.value.toLowerCase().trim();
    const filtered = !q ? allTracks : allTracks.filter(t => 
      t.title.toLowerCase().includes(q) || t.artist.toLowerCase().includes(q)
    );
    renderTracks(filtered);
  };

  if (searchInput) {
    searchInput.addEventListener('input', doSearch);
    searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });
  }
  if (searchBtn) searchBtn.addEventListener('click', doSearch);
</script>