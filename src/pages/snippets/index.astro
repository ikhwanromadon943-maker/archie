---
import Base from '../../layouts/Base.astro';
---
<Base title="Code Library" description="Fragments of logic, syntax, and solutions.">

  <header class="snip-hdr">
    <h1>Code Library</h1>
    <p>Fragments of logic, syntax, and solutions.</p>
  </header>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div class="snip-feed" id="snip-list"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </div>
    <h3>No snippets yet.</h3>
    <p>The first snippet has yet to be saved.</p>
  </div>

  <!-- Code Modal -->
  <div class="modal-overlay" id="snip-modal">
    <div class="modal">
      <div class="modal-header">
        <h2 class="modal-title" id="modal-title">—</h2>
        <button class="modal-close" id="modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <p class="modal-desc" id="modal-desc"></p>
      <div class="code-wrapper">
        <div class="code-header">
          <span id="modal-lang">js</span>
          <button class="code-copy" id="copy-btn">copy</button>
        </div>
        <pre class="code-body"><code id="modal-code"></code></pre>
      </div>
      <div class="modal-like-row">
        <button class="modal-like-btn" id="modal-like-btn" aria-label="Like">
          <svg id="modal-like-svg" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span id="modal-like-count">0</span>
        </button>
      </div>
    </div>
  </div>

</Base>


<script>
  import { supabase } from '../../lib/supabase';

  const LS_LIKED = 'liked_snippets_v1';
  const getLikedSnips = (): Set<string> => {
    try { return new Set(JSON.parse(localStorage.getItem(LS_LIKED)||'[]')); }
    catch { return new Set(); }
  };
  const saveLikedSnips = (s: Set<string>) => localStorage.setItem(LS_LIKED, JSON.stringify([...s]));

  const fdate = (iso: string) => new Date(iso).toLocaleDateString('en-US',{month:'numeric',day:'numeric',year:'numeric'});
  let currentSnippet: any = null;
  let currentCode = '';

  function getLangClass(lang: string) {
    const l = lang?.toLowerCase() || '';
    if (['js','javascript'].includes(l)) return 'lang-js';
    if (['ts','typescript'].includes(l)) return 'lang-ts';
    if (['py','python'].includes(l))     return 'lang-py';
    if (['sh','bash','shell'].includes(l)) return 'lang-sh';
    if (l === 'css')  return 'lang-css';
    if (l === 'html') return 'lang-html';
    if (l === 'json') return 'lang-json';
    return 'lang-other';
  }

  // In-memory views cache so card updates after modal close
  const viewsCache: Record<string, number> = {};
  const likesCache: Record<string, number> = {};

  function updateCardStats(id: string) {
    const card = document.querySelector<HTMLElement>(`.snip-card[data-id="${id}"]`);
    if (!card) return;
    const vEl = card.querySelector('.snip-stat-views span');
    const lEl = card.querySelector('.snip-stat-likes span');
    if (vEl && viewsCache[id] !== undefined) vEl.textContent = String(viewsCache[id]);
    if (lEl && likesCache[id] !== undefined) lEl.textContent = String(likesCache[id]);
  }

  function openModal(s: any) {
    currentSnippet = s;
    currentCode = s.code;

    document.getElementById('modal-title')!.textContent = s.title;
    document.getElementById('modal-desc')!.textContent  = s.description || '';
    document.getElementById('modal-lang')!.textContent  = s.language;
    document.getElementById('modal-code')!.textContent  = s.code;
    document.getElementById('snip-modal')!.classList.add('open');

    // Like state
    const liked = getLikedSnips();
    const isLiked = liked.has(s.id);
    const likeBtn = document.getElementById('modal-like-btn')!;
    const likeSvg = document.getElementById('modal-like-svg')!;
    const likeCount = document.getElementById('modal-like-count')!;
    const curLikes = likesCache[s.id] ?? s.likes ?? 0;
    likeCount.textContent = String(curLikes);
    if (isLiked) {
      likeBtn.classList.add('liked');
      likeSvg.setAttribute('fill','#ef4444');
      likeSvg.setAttribute('stroke','#ef4444');
    } else {
      likeBtn.classList.remove('liked');
      likeSvg.setAttribute('fill','none');
      likeSvg.setAttribute('stroke','currentColor');
    }

    // Increment views permanently
    const newViews = (viewsCache[s.id] ?? s.views ?? 0) + 1;
    viewsCache[s.id] = newViews;
    updateCardStats(s.id);
    supabase.rpc('increment_views', {row_id: s.id});
  }

  async function render() {
    const loading = document.getElementById('loading')!;
    const list    = document.getElementById('snip-list')!;
    const empty   = document.getElementById('empty-state')!;

    const { data: snippets, error } =
      await supabase.from('snippets').select('*').order('created_at',{ascending:false});

    loading.style.display = 'none';
    if (error) { list.innerHTML=`<p class="err-msg">[error] ${error.message}</p>`; return; }
    if (!snippets?.length) { empty.style.display='block'; return; }

    snippets.forEach((s: any, i: number) => {
      viewsCache[s.id] = s.views ?? 0;
      likesCache[s.id] = s.likes ?? 0;

      const el = document.createElement('div');
      el.className = 'snip-card';
      el.dataset.id = s.id;
      el.style.cssText = `opacity:0;animation:fadeUp 0.4s ease ${i*0.06}s forwards`;

      el.innerHTML = `
        <div class="snip-card-body">
          <div class="snip-badge">
            <span class="snip-stat snip-stat-views">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <span>${s.views ?? 0}</span>
            </span>
            <div class="snip-sep"></div>
            <span class="snip-stat snip-stat-likes">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <span>${s.likes ?? 0}</span>
            </span>
          </div>

          <h3 class="snip-title">${s.title}</h3>
          ${s.description ? `<p class="snip-desc">${s.description}</p>` : ''}

          <div class="snip-foot">
            <span class="snip-lang ${getLangClass(s.language)}">${s.language || 'code'}</span>
            <span class="snip-date">${fdate(s.created_at)}</span>
          </div>
        </div>`;

      // Click animation + open
      el.addEventListener('click', () => {
        el.style.transition = 'transform 0.14s cubic-bezier(0.34,1.56,0.64,1)';
        el.style.transform = 'scale(0.97)';
        setTimeout(() => { el.style.transform = 'scale(1)'; }, 130);
        setTimeout(() => openModal(s), 80);
      });

      list.appendChild(el);
    });
  }

  render();

  // Modal like button
  document.getElementById('modal-like-btn')!.addEventListener('click', async function() {
    if (!currentSnippet) return;
    const id = currentSnippet.id;
    const liked = getLikedSnips();
    const isLiked = liked.has(id);
    const likeCount = document.getElementById('modal-like-count')!;
    const likeSvg   = document.getElementById('modal-like-svg')!;
    const cur = likesCache[id] ?? 0;

    if (isLiked) {
      liked.delete(id);
      this.classList.remove('liked');
      likeSvg.setAttribute('fill','none');
      likeSvg.setAttribute('stroke','currentColor');
      likesCache[id] = Math.max(0, cur - 1);
      await supabase.rpc('decrement_likes',{table_name:'snippets',row_id:id});
    } else {
      liked.add(id);
      this.classList.add('liked');
      likeSvg.setAttribute('fill','#ef4444');
      likeSvg.setAttribute('stroke','#ef4444');
      likesCache[id] = cur + 1;
      await supabase.rpc('increment_likes',{table_name:'snippets',row_id:id});
    }
    saveLikedSnips(liked);
    likeCount.textContent = String(likesCache[id]);
    updateCardStats(id);
  });

  document.getElementById('modal-close')!.addEventListener('click', () =>
    document.getElementById('snip-modal')!.classList.remove('open'));
  document.getElementById('snip-modal')!.addEventListener('click', (e) => {
    if (e.target === document.getElementById('snip-modal'))
      document.getElementById('snip-modal')!.classList.remove('open');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.getElementById('snip-modal')!.classList.remove('open');
  });
  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(currentCode).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'copied!';
      setTimeout(() => btn.textContent = 'copy', 2000);
    });
  });
</script>

<style>
  .modal-like-row {
    display:flex; justify-content:flex-end;
    margin-top:1rem; padding-top:0.75rem;
    border-top:1px solid rgba(241,245,249,0.95);
  }
  .modal-like-btn {
    display:flex; align-items:center; gap:0.4rem;
    font-size:0.75rem; font-family:monospace;
    color:#94a3b8; background:none; border:none;
    cursor:pointer; padding:0.3rem 0.65rem; border-radius:999px;
    transition:all 0.2s ease;
  }
  .modal-like-btn:hover { color:#ef4444; background:rgba(239,68,68,0.07); }
  .modal-like-btn.liked { color:#ef4444; }
  /* code tidak terlalu tebal */
  .code-body code { font-weight:300 !important; }
</style>
