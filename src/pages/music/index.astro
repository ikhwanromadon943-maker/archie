---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

  <div class="music-page">

    <!-- HEADER -->
    <div class="music-header">
      <div class="music-title">ARCHIE<span class="music-dot">.</span>MUSIC</div>
      <p class="music-sub">your personal soundtrack</p>
    </div>

    <!-- SEARCH + NOW PLAYING BAR -->
    <div class="music-top-bar">
      <div class="music-search-wrap">
        <span class="music-search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input type="text" id="searchInput" class="music-search-input" placeholder="Search tracks..." autocomplete="off"/>
      </div>

      <!-- NOW PLAYING TICKER -->
      <div id="nowPlayingBar" class="now-playing-bar" style="display:none">
        <div class="np-dot"></div>
        <div class="np-ticker-wrap">
          <span id="npText" class="np-ticker-text"></span>
        </div>
        <div class="np-controls">
          <button id="npPrev" class="np-btn" title="Previous">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
          </button>
          <button id="npPlayPause" class="np-btn np-play" title="Play/Pause">
            <svg id="npIconPlay" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg id="npIconPause" width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          </button>
          <button id="npNext" class="np-btn" title="Next">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
          </button>
        </div>
        <!-- Progress -->
        <div id="npProgress" class="np-progress">
          <div id="npProgressFill" class="np-progress-fill"></div>
        </div>
        <span id="npTime" class="np-time">0:00</span>
      </div>
    </div>

    <!-- GRID -->
    <div id="trackGrid" class="track-grid">
      <!-- Skeleton placeholders -->
      <div class="track-card skeleton"></div>
      <div class="track-card skeleton"></div>
      <div class="track-card skeleton"></div>
      <div class="track-card skeleton"></div>
      <div class="track-card skeleton"></div>
      <div class="track-card skeleton"></div>
    </div>

    <div id="emptyState" class="empty-state" style="display:none">
      <div class="empty-icon">♪</div>
      <div>No tracks found</div>
    </div>

    <audio id="audioPlayer"></audio>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  const audio = document.getElementById('audioPlayer') as HTMLAudioElement;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const trackGrid = document.getElementById('trackGrid')!;
  const emptyState = document.getElementById('emptyState')!;

  // Now playing bar
  const nowPlayingBar = document.getElementById('nowPlayingBar')!;
  const npText = document.getElementById('npText')!;
  const npProgressFill = document.getElementById('npProgressFill')!;
  const npProgress = document.getElementById('npProgress')!;
  const npTime = document.getElementById('npTime')!;
  const npIconPlay = document.getElementById('npIconPlay')!;
  const npIconPause = document.getElementById('npIconPause')!;

  let tracks: any[] = [];
  let filteredTracks: any[] = [];
  let currentTrack: any = null;
  let isPlaying = false;

  function fmt(sec: number): string {
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function setPlayingState(playing: boolean) {
    isPlaying = playing;
    // update np bar icons
    npIconPlay.style.display = playing ? 'none' : '';
    npIconPause.style.display = playing ? '' : 'none';
    // update active card button
    const activeCard = document.querySelector('.track-card.is-playing');
    if (activeCard) {
      const btnIcon = activeCard.querySelector('.card-play-icon') as HTMLElement;
      const btnPause = activeCard.querySelector('.card-pause-icon') as HTMLElement;
      if (btnIcon) btnIcon.style.display = playing ? 'none' : '';
      if (btnPause) btnPause.style.display = playing ? '' : 'none';
    }
  }

  function playTrack(track: any) {
    if (!track) return;
    currentTrack = track;

    // Remove is-playing from all cards
    document.querySelectorAll('.track-card.is-playing').forEach(c => {
      c.classList.remove('is-playing');
      const pi = c.querySelector('.card-play-icon') as HTMLElement;
      const pa = c.querySelector('.card-pause-icon') as HTMLElement;
      if (pi) pi.style.display = '';
      if (pa) pa.style.display = 'none';
    });

    // Add is-playing to current card
    const activeCard = document.querySelector(`.track-card[data-id="${track.id}"]`);
    if (activeCard) activeCard.classList.add('is-playing');

    // Now playing bar
    nowPlayingBar.style.display = 'flex';
    npText.textContent = `${track.title}  —  ${track.artist || ''}`;

    // Audio
    audio.src = track.url;
    audio.play().then(() => setPlayingState(true)).catch(() => setPlayingState(false));
  }

  function togglePlay() {
    if (!currentTrack) {
      if (filteredTracks.length > 0) playTrack(filteredTracks[0]);
      return;
    }
    if (audio.paused) {
      audio.play();
    } else {
      audio.pause();
    }
  }

  function playNext() {
    if (filteredTracks.length === 0) return;
    const idx = filteredTracks.findIndex(t => t.id === currentTrack?.id);
    playTrack(filteredTracks[idx < filteredTracks.length - 1 ? idx + 1 : 0]);
  }

  function playPrev() {
    if (filteredTracks.length === 0) return;
    const idx = filteredTracks.findIndex(t => t.id === currentTrack?.id);
    playTrack(filteredTracks[idx > 0 ? idx - 1 : filteredTracks.length - 1]);
  }

  // Audio events
  audio.addEventListener('timeupdate', () => {
    if (!audio.duration || isNaN(audio.duration)) return;
    const pct = (audio.currentTime / audio.duration) * 100;
    npProgressFill.style.width = pct + '%';
    npTime.textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);

    // Update active card progress
    const activeCard = document.querySelector('.track-card.is-playing');
    if (activeCard) {
      const fill = activeCard.querySelector('.card-progress-fill') as HTMLElement;
      if (fill) fill.style.width = pct + '%';
    }
  });
  audio.addEventListener('play', () => setPlayingState(true));
  audio.addEventListener('pause', () => setPlayingState(false));
  audio.addEventListener('ended', playNext);

  // NP bar progress click
  npProgress.addEventListener('click', (e) => {
    if (!audio.duration || isNaN(audio.duration)) return;
    const rect = npProgress.getBoundingClientRect();
    audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
  });

  document.getElementById('npPlayPause')!.addEventListener('click', togglePlay);
  document.getElementById('npNext')!.addEventListener('click', playNext);
  document.getElementById('npPrev')!.addEventListener('click', playPrev);

  // Render cards
  function renderGrid(list: any[]) {
    trackGrid.innerHTML = '';
    if (list.length === 0) {
      emptyState.style.display = 'flex';
      return;
    }
    emptyState.style.display = 'none';

    list.forEach((track, i) => {
      const card = document.createElement('div');
      card.className = 'track-card';
      card.dataset.id = track.id;
      if (currentTrack?.id === track.id) card.classList.add('is-playing');

      const isThisPlaying = currentTrack?.id === track.id && isPlaying;
      const hasCover = track.thumbnail && (track.thumbnail.startsWith('http') || track.thumbnail.startsWith('/'));

      card.innerHTML = `
        <div class="card-cover ${hasCover ? '' : 'card-cover-placeholder'}">
          ${hasCover
            ? `<img src="${track.thumbnail}" alt="${track.title}" class="card-cover-img" loading="lazy"/>`
            : `<span class="card-cover-note">♪</span>`
          }
          <div class="card-cover-overlay">
            <button class="card-play-btn" aria-label="Play">
              <svg class="card-play-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="${isThisPlaying ? 'display:none' : ''}"><path d="M8 5v14l11-7z"/></svg>
              <svg class="card-pause-icon" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="${isThisPlaying ? '' : 'display:none'}"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
            </button>
          </div>
          <div class="card-progress-bar">
            <div class="card-progress-fill" style="width:${currentTrack?.id === track.id ? (audio.currentTime / audio.duration * 100 || 0) : 0}%"></div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title">${track.title || 'Unknown'}</div>
          <div class="card-artist">${track.artist || '—'}</div>
        </div>
      `;

      card.style.animationDelay = `${i * 40}ms`;
      card.classList.add('card-appear');

      card.querySelector('.card-play-btn')!.addEventListener('click', (e) => {
        e.stopPropagation();
        if (currentTrack?.id === track.id) {
          togglePlay();
        } else {
          playTrack(track);
        }
      });

      trackGrid.appendChild(card);
    });
  }

  // Search
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    filteredTracks = q
      ? tracks.filter(t => t.title?.toLowerCase().includes(q) || t.artist?.toLowerCase().includes(q))
      : [...tracks];
    renderGrid(filteredTracks);
  });

  // Init
  (async () => {
    const { data, error } = await supabase.from('music').select('*').order('added_at', { ascending: false });
    trackGrid.innerHTML = '';
    if (data && data.length > 0) {
      tracks = data;
      filteredTracks = [...tracks];
      renderGrid(filteredTracks);
    } else {
      emptyState.style.display = 'flex';
    }
  })();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap');

  .music-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.25rem 4rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* HEADER */
  .music-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .music-title {
    font-family: 'Space Mono', monospace;
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #0f172a;
    line-height: 1;
  }
  .music-dot { color: #6495ED; }
  .music-sub {
    font-size: 0.8rem;
    color: #94a3b8;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 6px;
    font-family: 'Space Mono', monospace;
  }

  /* TOP BAR */
  .music-top-bar {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 2rem;
  }

  /* SEARCH */
  .music-search-wrap {
    position: relative;
  }
  .music-search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    display: flex;
    z-index: 2;
  }
  .music-search-input {
    width: 100%;
    padding: 11px 16px 11px 38px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.875rem;
    color: #0f172a;
    background: #fff;
    outline: none;
    font-family: 'DM Sans', sans-serif;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .music-search-input:focus {
    border-color: #6495ED;
    box-shadow: 0 0 0 3px rgba(100,149,237,0.12);
  }

  /* NOW PLAYING BAR */
  .now-playing-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #0f172a;
    border-radius: 12px;
    padding: 8px 14px;
    color: #fff;
    overflow: hidden;
  }
  .np-dot {
    width: 7px;
    height: 7px;
    background: #6495ED;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 1.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
  .np-ticker-wrap {
    flex: 1;
    overflow: hidden;
    white-space: nowrap;
    min-width: 0;
  }
  .np-ticker-text {
    font-size: 0.78rem;
    font-family: 'Space Mono', monospace;
    color: #e2e8f0;
    display: inline-block;
    white-space: nowrap;
  }
  .np-controls {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .np-btn {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.1);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .np-btn:hover { background: rgba(255,255,255,0.2); }
  .np-play { background: #6495ED; }
  .np-play:hover { background: #7ba6f2; }
  .np-progress {
    width: 80px;
    height: 3px;
    background: rgba(255,255,255,0.15);
    border-radius: 10px;
    cursor: pointer;
    flex-shrink: 0;
    overflow: hidden;
  }
  .np-progress-fill {
    height: 100%;
    background: #6495ED;
    border-radius: 10px;
    width: 0%;
    transition: width 0.1s linear;
  }
  .np-time {
    font-size: 0.65rem;
    font-family: 'Space Mono', monospace;
    color: #94a3b8;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* GRID */
  .track-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 16px;
  }

  @media (max-width: 400px) {
    .track-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  /* CARD */
  .track-card {
    border-radius: 14px;
    background: #fff;
    border: 1.5px solid #f1f5f9;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .track-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.09);
  }
  .track-card.is-playing {
    border-color: #6495ED;
    box-shadow: 0 6px 20px rgba(100,149,237,0.2);
  }

  /* Skeleton */
  .track-card.skeleton {
    background: linear-gradient(90deg, #f1f5f9 25%, #e8edf4 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    height: 190px;
    border: none;
  }
  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Card appear animation */
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .card-appear {
    animation: cardIn 0.35s ease both;
  }

  /* COVER */
  .card-cover {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: #f1f5f9;
    overflow: hidden;
  }
  .card-cover-placeholder {
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-cover-note {
    font-size: 2rem;
    color: #94a3b8;
    user-select: none;
  }
  .card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .track-card:hover .card-cover-img,
  .track-card.is-playing .card-cover-img {
    transform: scale(1.05);
  }

  /* Overlay with play button */
  .card-cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .track-card:hover .card-cover-overlay,
  .track-card.is-playing .card-cover-overlay {
    background: rgba(0,0,0,0.35);
  }
  .card-play-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: #0f172a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .track-card:hover .card-play-btn,
  .track-card.is-playing .card-play-btn {
    opacity: 1;
    transform: scale(1);
  }
  .card-play-btn:hover {
    background: #6495ED;
    color: #fff;
    transform: scale(1.08) !important;
  }

  /* Card progress bar (bottom of cover) */
  .card-progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255,255,255,0.2);
  }
  .card-progress-fill {
    height: 100%;
    background: #6495ED;
    transition: width 0.1s linear;
  }

  /* CARD INFO */
  .card-info {
    padding: 10px 12px 12px;
  }
  .card-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: #0f172a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
  }
  .card-artist {
    font-size: 0.72rem;
    color: #94a3b8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Playing label on card */
  .track-card.is-playing .card-title {
    color: #6495ED;
  }

  /* EMPTY STATE */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 4rem 0;
    color: #94a3b8;
    font-size: 0.9rem;
    font-family: 'Space Mono', monospace;
  }
  .empty-icon {
    font-size: 3rem;
  }
</style>
