---
import Base from '../../layouts/Base.astro';
---
<Base title="Login">
  <div class="login-outer">
    <div class="login-card">
      <div class="login-deco-1"></div>
      <div class="login-deco-2"></div>
      <div class="login-inner">
        <div class="login-icon-wrap">
          <div class="login-icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#6495ED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              <circle cx="12" cy="16.5" r="1"/>
            </svg>
          </div>
        </div>
        <h2 class="login-title">Owner Login</h2>
        <p class="login-eyebrow">RESTRICTED AREA · OWNER ONLY</p>

        <div id="login-error" class="login-error">Wrong passphrase. Try again.</div>

        <div class="login-field">
          <label class="login-label">SECRET PASSPHRASE</label>
          <div class="login-input-wrap">
            <div class="login-input-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 19l-1 1-1-1-2-2-2-2 1-1-1-1 3.586-3.586A6 6 0 0120 13V9a2 2 0 012-2h-2z"/>
              </svg>
            </div>
            <input type="password" id="login-pw" class="login-input" placeholder="••••••••" autocomplete="current-password"/>
          </div>
        </div>

        <button class="login-btn" id="login-btn">
          <span id="login-btn-text">Unlock Journal</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>

        <div class="login-back-wrap">
          <a href="/" class="login-back">Return to Home</a>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '../../lib/supabase';
  if (sessionStorage.getItem('admin_authed')==='1') window.location.href='/admin';

  async function getPass(): Promise<string> {
    const { data } = await supabase.from('settings').select('value').eq('key','admin_pass').single();
    return data?.value || 'mysite2025';
  }

  document.getElementById('login-btn')!.addEventListener('click', async () => {
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const txt = document.getElementById('login-btn-text')!;
    const pw = (document.getElementById('login-pw') as HTMLInputElement).value;
    const err = document.getElementById('login-error')!;
    btn.disabled=true; txt.textContent='Checking...';
    const correct = await getPass();
    if (pw===correct) {
      sessionStorage.setItem('admin_authed','1');
      window.location.href='/admin';
    } else {
      err.classList.add('show');
      btn.disabled=false; txt.textContent='Unlock Journal';
      (document.getElementById('login-pw') as HTMLInputElement).value='';
    }
  });
  document.getElementById('login-pw')!.addEventListener('keydown',(e)=>{ if((e as KeyboardEvent).key==='Enter') document.getElementById('login-btn')!.click(); });
</script>
