---
import Base from '../../layouts/Base.astro';
---
<Base title="Gallery" description="Moments frozen in time.">

  <header class="gallery-hdr">
    <h1>Visual Memories</h1>
    <div class="gallery-hdr-line"></div>
    <p>Moments frozen in time, kept safe forever in this digital garden.</p>
  </header>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div class="gallery-feed" id="gallery-feed"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    </div>
    <h3>No photos yet.</h3>
    <p>The gallery awaits its first memory.</p>
  </div>



</Base>


<script>
  import { supabase } from '../../lib/supabase';

  const LS_KEY = 'liked_gallery_v2';
  const getLiked = (): Set<string> => {
    try { return new Set(JSON.parse(localStorage.getItem(LS_KEY)||'[]')); }
    catch { return new Set(); }
  };
  const saveLiked = (s: Set<string>) => localStorage.setItem(LS_KEY, JSON.stringify([...s]));
  const fdate = (iso: string) => new Date(iso).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});

  async function render() {
    const loading = document.getElementById('loading')!;
    const feed    = document.getElementById('gallery-feed')!;
    const empty   = document.getElementById('empty-state')!;

    const { data: items, error } =
      await supabase.from('gallery').select('*').order('created_at',{ascending:false});

    loading.style.display = 'none';
    if (error || !items?.length) { empty.style.display='block'; return; }

    const liked = getLiked();

    items.forEach((item: any, i: number) => {
      const isLiked  = liked.has(item.id);
      const hFill    = isLiked ? '#ef4444' : 'none';
      const hStroke  = isLiked ? '#ef4444' : 'rgba(255,255,255,0.92)';
      const hasBottom = item.title || item.caption;

      const el = document.createElement('div');
      el.className = 'gallery-card';
      el.style.cssText = `opacity:0;animation:fadeUp 0.45s ease ${i*0.08}s forwards`;

      el.innerHTML = `
        <div class="gallery-card-img-wrap">
          <img src="${item.url}" alt="${item.title||'Memory'}" loading="lazy" class="gallery-card-img"/>
          <div class="gallery-card-img-grad"></div>
          <div class="gallery-card-img-info">
            <div class="gallery-card-img-text">
              <div class="gallery-card-date">${fdate(item.created_at)}</div>
              <div class="gallery-card-title">${item.title || 'Untitled Memory'}</div>
              ${item.caption ? `<div class="gallery-card-caption">${item.caption}</div>` : ''}
            </div>
            <button class="gallery-like-btn${isLiked?' liked':''}"
              data-id="${item.id}" data-liked="${isLiked}" aria-label="Like">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                viewBox="0 0 24 24" fill="${hFill}" stroke="${hStroke}"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <span class="lc">${item.likes ?? 0}</span>
            </button>
          </div>
        </div>`;

      /* click — animasi maju tipis, tanpa lightbox/zoom */
      el.querySelector('.gallery-card-img-wrap')!.addEventListener('click', (e) => {
        if ((e.target as Element).closest('.gallery-like-btn')) return;
        el.style.transition = 'transform 0.18s cubic-bezier(0.22,1,0.36,1), box-shadow 0.18s ease';
        el.style.transform  = 'translateY(-6px)';
        el.style.boxShadow  = '0 20px 48px rgba(100,149,237,0.22)';
        setTimeout(() => {
          el.style.transition = 'transform 0.3s ease, box-shadow 0.3s ease';
          el.style.transform  = '';
          el.style.boxShadow  = '';
        }, 280);
      });

      /* like — tersimpan permanent di Supabase + localStorage */
      el.querySelector<HTMLButtonElement>('.gallery-like-btn')!.addEventListener('click', async function(e) {
        e.stopPropagation();
        const wasLiked = this.dataset.liked === 'true';
        const liked    = getLiked();
        const lc       = this.querySelector('.lc')!;
        const svg      = this.querySelector('svg')!;
        const cur      = parseInt(lc.textContent || '0');

        if (wasLiked) {
          liked.delete(item.id); this.dataset.liked='false'; this.classList.remove('liked');
          svg.setAttribute('fill','none'); svg.setAttribute('stroke','rgba(255,255,255,0.92)');
          lc.textContent = String(Math.max(0, cur - 1));
          await supabase.rpc('decrement_likes',{table_name:'gallery',row_id:item.id});
        } else {
          liked.add(item.id); this.dataset.liked='true'; this.classList.add('liked');
          svg.setAttribute('fill','#ef4444'); svg.setAttribute('stroke','#ef4444');
          lc.textContent = String(cur + 1);
          await supabase.rpc('increment_likes',{table_name:'gallery',row_id:item.id});
        }
        saveLiked(liked);
      });

      feed.appendChild(el);
    });
  }

  render();
</script>
