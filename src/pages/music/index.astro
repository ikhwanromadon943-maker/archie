---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

  <div class="music-hero">
    <h1 class="music-big-title">ARCHIE<span class="music-dot">.</span>MUSIC</h1>
    <div class="music-search-row">
      <div class="music-search-wrap">
        <div class="music-search-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <input type="text" id="music-search" class="music-search-input" placeholder="Search song..."/>
      </div>
      <button id="music-search-btn" class="music-search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </div>
  </div>

  <!-- Mini Player -->
  <div class="mini-player" id="mini-player" style="display:none">
    <img class="mp-thumb" id="mp-thumb" src="" alt=""/>
    <div class="mp-info">
      <div class="mp-title" id="mp-title">—</div>
      <div class="mp-artist" id="mp-artist">—</div>
    </div>
    <button class="mp-play-btn" id="mp-play" title="Play/Pause">
      <svg id="mp-play-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      <svg id="mp-pause-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
    </button>
  </div>

  <audio id="audio-player"></audio>

  <div class="loading-state" id="loading"><span class="loader"></span></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
    </div>
    <h3>No tracks yet.</h3>
    <p>Add tracks via the admin panel.</p>
  </div>

</Base>

<script>
  import { supabase } from '../../lib/supabase';

  let allTracks: any[] = [];
  let currentIdx = -1;
  let isPlaying = false;

  const audio = document.getElementById('audio-player') as HTMLAudioElement;
  const player = document.getElementById('mini-player')!;
  const mpTitle = document.getElementById('mp-title')!;
  const mpArtist = document.getElementById('mp-artist')!;
  const mpThumb = document.getElementById('mp-thumb') as HTMLImageElement;
  const playIcon = document.getElementById('mp-play-icon')!;
  const pauseIcon = document.getElementById('mp-pause-icon')!;

  function setPlayUI(playing: boolean) {
    isPlaying = playing;
    playIcon.style.display = playing ? 'none' : 'block';
    pauseIcon.style.display = playing ? 'block' : 'none';
  }

  function loadTrack(idx: number) {
    const t = allTracks[idx];
    if (!t) return;
    currentIdx = idx;
    mpTitle.textContent = t.title;
    mpArtist.textContent = t.artist;
    mpThumb.src = t.thumbnail || '';
    mpThumb.style.display = t.thumbnail ? 'block' : 'none';
    player.style.display = 'flex';

    if (t.url) {
      audio.src = t.url;
      audio.play().then(() => setPlayUI(true)).catch(() => setPlayUI(false));
    } else {
      setPlayUI(false);
    }
  }

  document.getElementById('mp-play')!.addEventListener('click', () => {
    if (allTracks.length === 0) return;
    
    if (currentIdx === -1) {
      // First time: play first track
      loadTrack(0);
    } else if (isPlaying) {
      audio.pause();
      setPlayUI(false);
    } else {
      audio.play();
      setPlayUI(true);
    }
  });

  audio.addEventListener('ended', () => {
    if (currentIdx < allTracks.length - 1) {
      loadTrack(currentIdx + 1);
    } else {
      setPlayUI(false);
    }
  });

  audio.addEventListener('pause', () => setPlayUI(false));
  audio.addEventListener('play', () => setPlayUI(true));

  async function loadTracks() {
    const loading = document.getElementById('loading')!;
    const empty = document.getElementById('empty-state')!;
    const { data: items, error } = await supabase.from('music').select('*').order('added_at', { ascending: false });
    loading.style.display = 'none';
    if (error || !items?.length) {
      empty.style.display = 'block';
      return;
    }
    allTracks = items;
  }

  loadTracks();
</script>

<style>
  .music-hero { text-align:center; padding:3rem 0 2rem; }
  .music-big-title { font-family:'Inter',system-ui,sans-serif; font-size:clamp(2.5rem,11vw,4.2rem); font-weight:700; letter-spacing:-0.02em; color:#1e293b; margin-bottom:2.5rem; line-height:1; }
  .music-dot { color:#6495ED; }

  .music-search-row { display:flex; gap:0.5rem; max-width:400px; margin:0 auto; }
  .music-search-wrap { flex:1; position:relative; }
  .music-search-icon { position:absolute; left:0.9rem; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; display:flex; }
  .music-search-input { width:100%; background:rgba(255,255,255,0.7); backdrop-filter:blur(10px); border:1.5px solid rgba(255,255,255,0.85); border-radius:999px; padding:0.7rem 1rem 0.7rem 2.5rem; font-size:0.875rem; color:#1e293b; outline:none; transition:border-color 0.2s ease, box-shadow 0.2s ease; }
  .music-search-input:focus { border-color:#6495ED; box-shadow:0 0 0 3px rgba(100,149,237,0.12); }
  .music-search-btn { width:42px; height:42px; border-radius:50%; background:#6495ED; color:#fff; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0; transition:background 0.2s, transform 0.2s; box-shadow:0 4px 12px rgba(100,149,237,0.3); }
  .music-search-btn:hover { background:#5b89dc; transform:scale(1.05); }

  /* Mini Player - Compact & Clean */
  .mini-player {
    display:flex;
    align-items:center;
    gap:0.75rem;
    background:rgba(255,255,255,0.8);
    backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px);
    border:1px solid rgba(255,255,255,0.9);
    border-radius:16px;
    padding:0.7rem 1rem;
    max-width:380px;
    margin:0 auto;
    box-shadow:0 4px 20px rgba(100,149,237,0.12);
    transition:all 0.3s ease;
  }
  .mp-thumb {
    width:42px;
    height:42px;
    border-radius:10px;
    object-fit:cover;
    flex-shrink:0;
  }
  .mp-info {
    flex:1;
    min-width:0;
  }
  .mp-title {
    font-size:0.85rem;
    font-weight:600;
    color:#1e293b;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
  }
  .mp-artist {
    font-size:0.7rem;
    color:#94a3b8;
    margin-top:2px;
  }
  .mp-play-btn {
    display:flex;
    align-items:center;
    justify-content:center;
    width:40px;
    height:40px;
    border-radius:50%;
    background:#6495ED;
    color:#fff;
    border:none;
    cursor:pointer;
    flex-shrink:0;
    box-shadow:0 4px 12px rgba(100,149,237,0.35);
    transition:background 0.2s, transform 0.15s;
  }
  .mp-play-btn:hover {
    background:#5b89dc;
    transform:scale(1.06);
  }
</style>