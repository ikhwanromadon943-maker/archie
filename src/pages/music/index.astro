---
import Base from '../../layouts/Base.astro';
---
<Base title="Music" description="Music player.">

<div class="sp-wrap">

  <!-- Header -->
  <div class="sp-head">
    <h1 class="sp-title">ARCHIE<span class="sp-dot">.</span>MUSIC</h1>
    <p class="sp-sub" id="spSub">Loading...</p>
  </div>

  <!-- Search row -->
  <div class="sp-search-row">
    <div class="sp-search-box">
      <svg class="sp-search-ico" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="searchInput" class="sp-search-input" type="text" placeholder="Search songs, artists..." autocomplete="off"/>
    </div>
    <button id="searchBtn" class="sp-search-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
  </div>

  <!-- Track list -->
  <div id="trackList" class="sp-tracklist">
    <div class="sp-loading"><div class="sp-spinner"></div></div>
  </div>

</div>

<!-- Bottom Player -->
<div id="spPlayer" class="sp-player" style="display:none">
  <div id="spThumb" class="sp-player-thumb">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
  </div>
  <div class="sp-player-info">
    <div class="sp-player-title" id="spTitle">—</div>
    <div class="sp-player-artist" id="spArtist">—</div>
  </div>
  <div class="sp-player-btns">
    <button id="btnPrev" class="sp-btn-sm"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg></button>
    <button id="btnPlay" class="sp-btn-play">
      <svg id="icoPlay" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      <svg id="icoPause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
    <button id="btnNext" class="sp-btn-sm"><svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg></button>
  </div>
  <div class="sp-player-prog">
    <div id="progBar" class="sp-prog-bar"><div id="progFill" class="sp-prog-fill"></div></div>
    <div id="progTime" class="sp-prog-time">0:00 / 0:00</div>
  </div>
</div>

<audio id="audioEl" preload="none"></audio>

</Base>

<script>
import { supabase } from '../../lib/supabase';

const audio       = document.getElementById('audioEl') as HTMLAudioElement;
const trackList   = document.getElementById('trackList')!;
const searchInput = document.getElementById('searchInput') as HTMLInputElement;
const spPlayer    = document.getElementById('spPlayer')!;
const spTitle     = document.getElementById('spTitle')!;
const spArtist    = document.getElementById('spArtist')!;
const spThumb     = document.getElementById('spThumb')!;
const spSub       = document.getElementById('spSub')!;
const progFill    = document.getElementById('progFill')!;
const progBar     = document.getElementById('progBar')!;
const progTime    = document.getElementById('progTime')!;
const icoPlay     = document.getElementById('icoPlay')!;
const icoPause    = document.getElementById('icoPause')!;

let allTracks: any[] = [];
let currentId: any   = null;

const fmt = (s: number) => isNaN(s) ? '0:00' : `${Math.floor(s/60)}:${String(Math.floor(s%60)).padStart(2,'0')}`;

function syncIco() {
  const p = !audio.paused && !audio.ended;
  icoPlay.style.display  = p ? 'none' : '';
  icoPause.style.display = p ? '' : 'none';
  document.querySelectorAll<HTMLElement>('.sp-card').forEach(el => {
    const active = el.dataset.id === String(currentId);
    el.classList.toggle('active', active);
    const ico = el.querySelector('.sp-card-ico')!;
    if (!ico) return;
    ico.innerHTML = active && p
      ? `<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`
      : `<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`;
  });
}

function playTrack(t: any) {
  currentId = t.id;
  spPlayer.style.display = '';
  spTitle.textContent    = t.title  || 'Unknown';
  spArtist.textContent   = t.artist || '—';
  spThumb.innerHTML = t.thumbnail
    ? `<img src="${t.thumbnail}" alt="${t.title}" style="width:100%;height:100%;object-fit:cover;border-radius:10px"/>`
    : `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`;
  audio.pause(); audio.src = ''; audio.load();
  audio.src = t.url;
  progFill.style.width = '0%';
  progTime.textContent = '0:00 / 0:00';
  audio.play().catch(()=>{});
}

function getList() {
  const q = searchInput.value.toLowerCase().trim();
  return q ? allTracks.filter(t => t.title?.toLowerCase().includes(q) || t.artist?.toLowerCase().includes(q)) : allTracks;
}

function playNext() { const l=getList(), i=l.findIndex(t=>t.id===currentId); playTrack(l[(i+1)%l.length]); }
function playPrev() { const l=getList(), i=l.findIndex(t=>t.id===currentId); playTrack(l[i<=0?l.length-1:i-1]); }
function togglePlay() {
  if (!currentId) { const l=getList(); if(l.length) playTrack(l[0]); return; }
  audio.paused ? audio.play().catch(()=>{}) : audio.pause();
}

audio.addEventListener('play', syncIco);
audio.addEventListener('pause', syncIco);
audio.addEventListener('ended', () => { syncIco(); playNext(); });
audio.addEventListener('timeupdate', () => {
  if (!audio.duration || isNaN(audio.duration)) return;
  progFill.style.width = (audio.currentTime/audio.duration*100)+'%';
  progTime.textContent = fmt(audio.currentTime)+' / '+fmt(audio.duration);
});
progBar.addEventListener('click', e => {
  if (!audio.duration || isNaN(audio.duration)) return;
  const r = progBar.getBoundingClientRect();
  audio.currentTime = ((e.clientX-r.left)/r.width)*audio.duration;
});

document.getElementById('btnPlay')!.addEventListener('click', togglePlay);
document.getElementById('btnNext')!.addEventListener('click', playNext);
document.getElementById('btnPrev')!.addEventListener('click', playPrev);

function renderTracks(list: any[]) {
  if (!list.length) { trackList.innerHTML = `<div class="sp-empty">No tracks found.</div>`; return; }
  const playing = !audio.paused && !audio.ended;
  trackList.innerHTML = list.map((t,i) => {
    const isActive = String(t.id) === String(currentId);
    return `
    <div class="sp-card ${isActive ? 'active' : ''}" data-id="${t.id}">
      <span class="sp-card-num">${i+1}</span>
      <div class="sp-card-thumb">
        ${t.thumbnail
          ? `<img src="${t.thumbnail}" alt="${t.title}" loading="lazy"/>`
          : `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`}
      </div>
      <div class="sp-card-info">
        <div class="sp-card-title">${t.title||'Unknown'}</div>
        <div class="sp-card-artist">${t.artist||'—'}</div>
      </div>
      <div class="sp-card-right">
        <span class="sp-card-dur">${t.duration||''}</span>
        <span class="sp-card-ico">
          ${isActive && playing
            ? `<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`
            : `<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`}
        </span>
      </div>
    </div>`;
  }).join('');
  trackList.querySelectorAll<HTMLElement>('.sp-card').forEach(el => {
    el.addEventListener('click', () => {
      const t = allTracks.find(x => String(x.id) === el.dataset.id);
      if (!t) return;
      String(currentId) === el.dataset.id ? togglePlay() : playTrack(t);
    });
  });
}

searchInput.addEventListener('input', () => renderTracks(getList()));
document.getElementById('searchBtn')!.addEventListener('click', () => renderTracks(getList()));

(async () => {
  const { data } = await supabase.from('music').select('*').order('added_at', { ascending: false });
  if (data?.length) {
    allTracks = data;
    spSub.textContent = `${data.length} tracks`;
    renderTracks(allTracks);
  } else {
    spSub.textContent = 'No tracks yet';
    trackList.innerHTML = `<div class="sp-empty">Add tracks in admin panel.</div>`;
  }
})();
</script>

<style>
  .sp-wrap {
    max-width: 500px;
    margin: 0 auto;
    padding: 2.5rem 1rem 11rem;
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* HEADER */
  .sp-head { margin-bottom: 1.5rem; }
  .sp-title {
    font-size: clamp(1.8rem, 8vw, 2.6rem);
    font-weight: 700; letter-spacing: -0.03em;
    color: #1e293b; line-height: 1;
  }
  .sp-dot { color: #6495ED; }
  .sp-sub { font-size: 0.78rem; color: #94a3b8; margin-top: 0.3rem; }

  /* SEARCH */
  .sp-search-row {
    display: flex; align-items: center;
    gap: 8px; margin-bottom: 1.25rem;
  }
  .sp-search-box {
    flex: 1; position: relative;
  }
  .sp-search-ico {
    position: absolute; left: 13px; top: 50%;
    transform: translateY(-50%);
    color: #94a3b8; pointer-events: none;
  }
  .sp-search-input {
    width: 100%; padding: 10px 14px 10px 38px;
    border: 1.5px solid #e2e8f0; border-radius: 50px;
    font-size: 0.85rem; color: #1e293b;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(8px); outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .sp-search-input:focus {
    border-color: #6495ED;
    box-shadow: 0 0 0 3px rgba(100,149,237,.12);
  }
  .sp-search-btn {
    width: 42px; height: 42px; border-radius: 50%;
    border: none; background: #6495ED; color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(100,149,237,.4);
    transition: background .2s, transform .15s;
  }
  .sp-search-btn:hover  { background: #5b89dc; transform: scale(1.06); }
  .sp-search-btn:active { transform: scale(0.94); }

  /* CARD LIST */
  .sp-tracklist { display: flex; flex-direction: column; gap: 4px; }

  .sp-card {
    display: flex; align-items: center; gap: 10px;
    padding: 7px 10px; border-radius: 12px;
    cursor: pointer; transition: background .15s;
    border: 1px solid transparent;
  }
  .sp-card:hover  { background: rgba(100,149,237,.06); border-color: rgba(100,149,237,.1); }
  .sp-card.active { background: rgba(100,149,237,.1); border-color: rgba(100,149,237,.2); }

  .sp-card-num {
    width: 18px; text-align: center;
    font-size: 0.72rem; color: #94a3b8;
    font-family: monospace; flex-shrink: 0; line-height: 1;
  }
  .sp-card.active .sp-card-num { color: #6495ED; }
  .sp-card:hover .sp-card-num  { visibility: hidden; }

  .sp-card-thumb {
    width: 36px !important; height: 36px !important;
    min-width: 36px !important; max-width: 36px !important;
    min-height: 36px !important; max-height: 36px !important;
    border-radius: 7px; overflow: hidden;
    background: rgba(100,149,237,.08);
    display: flex; align-items: center;
    justify-content: center; color: #94a3b8;
    flex-shrink: 0;
  }
  .sp-card-thumb img {
    width: 36px !important; height: 36px !important;
    min-width: 36px !important; max-width: 36px !important;
    min-height: 36px !important; max-height: 36px !important;
    object-fit: cover !important; display: block !important;
  }

  .sp-card-info { flex: 1; min-width: 0; }
  .sp-card-title {
    font-size: 0.83rem; font-weight: 600; color: #1e293b;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sp-card.active .sp-card-title { color: #6495ED; }
  .sp-card-artist {
    font-size: 0.68rem; color: #94a3b8; margin-top: 1px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .sp-card-right {
    display: flex; align-items: center; gap: 8px; flex-shrink: 0;
  }
  .sp-card-dur {
    font-size: 0.68rem; color: #94a3b8; font-family: monospace;
  }
  .sp-card-ico {
    width: 24px; height: 24px; border-radius: 50%;
    background: #6495ED; color: #fff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; opacity: 0;
    box-shadow: 0 2px 6px rgba(100,149,237,.4);
    transition: opacity .15s;
  }
  .sp-card:hover .sp-card-ico,
  .sp-card.active .sp-card-ico { opacity: 1; }

  /* LOADING / EMPTY */
  .sp-loading {
    display: flex; justify-content: center; padding: 4rem 0;
  }
  .sp-spinner {
    width: 26px; height: 26px;
    border: 2.5px solid rgba(100,149,237,.2);
    border-top-color: #6495ED; border-radius: 50%;
    animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .sp-empty {
    text-align: center; padding: 3rem 0;
    color: #94a3b8; font-size: 0.85rem;
  }

  /* PLAYER */
  .sp-player {
    position: fixed;
    bottom: 76px;
    left: 50%; transform: translateX(-50%);
    width: calc(100% - 2rem); max-width: 480px;
    background: rgba(255,255,255,0.93);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.85);
    border-radius: 20px;
    padding: 11px 14px 9px;
    box-shadow: 0 8px 32px rgba(0,0,0,.12), 0 2px 8px rgba(100,149,237,.12);
    z-index: 30;
    display: flex; flex-wrap: wrap;
    align-items: center; gap: 10px;
    animation: slideUp .3s cubic-bezier(.22,1,.36,1);
  }
  @keyframes slideUp {
    from { opacity:0; transform: translateX(-50%) translateY(16px); }
    to   { opacity:1; transform: translateX(-50%) translateY(0); }
  }
  .sp-player-thumb {
    width: 40px; height: 40px; min-width: 40px;
    border-radius: 9px; overflow: hidden;
    background: rgba(100,149,237,.1);
    display: flex; align-items: center; justify-content: center;
    color: #94a3b8; flex-shrink: 0;
  }
  .sp-player-info { flex: 1; min-width: 0; }
  .sp-player-title {
    font-size: 0.83rem; font-weight: 600; color: #1e293b;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sp-player-artist { font-size: 0.7rem; color: #94a3b8; margin-top: 1px; }
  .sp-player-btns { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .sp-btn-sm {
    width: 30px; height: 30px; border-radius: 50%;
    border: none; background: rgba(100,149,237,.08);
    color: #6495ED; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s;
  }
  .sp-btn-sm:hover { background: rgba(100,149,237,.18); }
  .sp-btn-play {
    width: 38px; height: 38px; border-radius: 50%;
    border: none; background: #6495ED; color: #fff;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 12px rgba(100,149,237,.4);
    transition: background .15s, transform .15s;
  }
  .sp-btn-play:hover { background: #5b89dc; transform: scale(1.06); }
  .sp-btn-play:active { transform: scale(.94); }
  .sp-player-prog { width: 100%; }
  .sp-prog-bar {
    width: 100%; height: 3px;
    background: rgba(100,149,237,.15);
    border-radius: 10px; cursor: pointer; overflow: hidden;
  }
  .sp-prog-fill {
    height: 100%; background: #6495ED;
    border-radius: 10px; width: 0%;
    transition: width .1s linear;
  }
  .sp-prog-time {
    font-size: 0.6rem; font-family: monospace;
    color: #94a3b8; text-align: right; margin-top: 3px;
  }
</style>
